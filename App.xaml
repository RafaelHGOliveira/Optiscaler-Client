<Application x:Class="OptiscalerManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OptiscalerManager"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Languages/Strings.en.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <!-- ═══════════════════════════════════════════════════════════
             PALETA "ANOCHECER" — Dark dusk theme
             ═══════════════════════════════════════════════════════════ -->

        <!-- Backgrounds -->
        <Color x:Key="BgDeepColor">#0E0E1A</Color>
        <Color x:Key="BgBaseColor">#13131F</Color>
        <Color x:Key="BgSurfaceColor">#1C1C2E</Color>
        <Color x:Key="BgCardColor">#1E1E30</Color>
        <Color x:Key="BgElevatedColor">#252540</Color>

        <!-- Borders -->
        <Color x:Key="BorderSubtleColor">#2A2A42</Color>
        <Color x:Key="BorderDefaultColor">#363660</Color>

        <!-- Accent - Violeta -->
        <Color x:Key="AccentPrimaryColor">#8B73F8</Color>
        <Color x:Key="AccentPrimaryHoverColor">#9D88FF</Color>
        <Color x:Key="AccentPrimaryPressedColor">#7560E0</Color>

        <!-- Accent - Naranja atardecer -->
        <Color x:Key="AccentWarmColor">#F0834A</Color>
        <Color x:Key="AccentWarmHoverColor">#F59560</Color>

        <!-- Text -->
        <Color x:Key="TextPrimaryColor">#E4E4EF</Color>
        <Color x:Key="TextSecondaryColor">#8A8AAA</Color>
        <Color x:Key="TextDisabledColor">#4A4A65</Color>

        <!-- Status -->
        <Color x:Key="StatusSuccessColor">#5CB87E</Color>
        <Color x:Key="StatusErrorColor">#E06060</Color>
        <Color x:Key="StatusWarningColor">#D4A04A</Color>

        <!-- SolidColorBrushes -->
        <SolidColorBrush x:Key="BrBgDeep"     Color="{StaticResource BgDeepColor}"/>
        <SolidColorBrush x:Key="BrBgBase"     Color="{StaticResource BgBaseColor}"/>
        <SolidColorBrush x:Key="BrBgSurface"  Color="{StaticResource BgSurfaceColor}"/>
        <SolidColorBrush x:Key="BrBgCard"     Color="{StaticResource BgCardColor}"/>
        <SolidColorBrush x:Key="BrBgElevated" Color="{StaticResource BgElevatedColor}"/>

        <SolidColorBrush x:Key="BrBorderSubtle"  Color="{StaticResource BorderSubtleColor}"/>
        <SolidColorBrush x:Key="BrBorderDefault" Color="{StaticResource BorderDefaultColor}"/>

        <SolidColorBrush x:Key="BrAccent"          Color="{StaticResource AccentPrimaryColor}"/>
        <SolidColorBrush x:Key="BrAccentHover"     Color="{StaticResource AccentPrimaryHoverColor}"/>
        <SolidColorBrush x:Key="BrAccentPressed"   Color="{StaticResource AccentPrimaryPressedColor}"/>
        <SolidColorBrush x:Key="BrAccentWarm"      Color="{StaticResource AccentWarmColor}"/>
        <SolidColorBrush x:Key="BrAccentWarmHover" Color="{StaticResource AccentWarmHoverColor}"/>

        <SolidColorBrush x:Key="BrTextPrimary"   Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="BrTextSecondary" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="BrTextDisabled"  Color="{StaticResource TextDisabledColor}"/>

        <SolidColorBrush x:Key="BrSuccess" Color="{StaticResource StatusSuccessColor}"/>
        <SolidColorBrush x:Key="BrError"   Color="{StaticResource StatusErrorColor}"/>
        <SolidColorBrush x:Key="BrWarning" Color="{StaticResource StatusWarningColor}"/>

        <!-- ═══════════════════════════════════════════════════════════
             TYPOGRAPHY  (Segoe UI Variable — Windows 11 native font)
             ═══════════════════════════════════════════════════════════ -->
        <FontFamily x:Key="FontPrimary">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
        <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeCaption">11</System:Double>
        <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeBody">13</System:Double>
        <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeBodyLarge">15</System:Double>
        <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeSubtitle">18</System:Double>
        <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeTitle">22</System:Double>

        <!-- ═══════════════════════════════════════════════════════════
             CORNER RADIUS
             ═══════════════════════════════════════════════════════════ -->
        <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
        <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
        <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
        <CornerRadius x:Key="RadiusXL">16</CornerRadius>
        <CornerRadius x:Key="RadiusPill">50</CornerRadius>

        <!-- ═══════════════════════════════════════════════════════════
             BASE BUTTON STYLE
             ═══════════════════════════════════════════════════════════ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="FontFamily"    Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"      Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Foreground"    Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="Background"    Value="{StaticResource BrBgElevated}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BrBorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="16,8"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrBgElevated}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button — violet accent -->
        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="{StaticResource BrAccent}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BrAccent}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrAccentPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button — red -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#3D1F1F"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrError}"/>
            <Setter Property="Foreground"  Value="{StaticResource BrError}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4D2525"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success button — green -->
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#1A3D2A"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrSuccess}"/>
            <Setter Property="Foreground"  Value="{StaticResource BrSuccess}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#224D34"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Warm/Orange button (NukemFG update) -->
        <Style x:Key="BtnWarm" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#3D2410"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrAccentWarm}"/>
            <Setter Property="Foreground"  Value="{StaticResource BrAccentWarm}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4D2D14"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default button style applied globally -->
        <Style TargetType="Button" BasedOn="{StaticResource BtnBase}"/>

        <!-- ═══════════════════════════════════════════════════════════
             TEXTBOX
             ═══════════════════════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily"         Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"           Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Foreground"         Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="Background"         Value="{StaticResource BrBgElevated}"/>
            <Setter Property="BorderBrush"        Value="{StaticResource BrBorderSubtle}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Padding"            Value="10,6"/>
            <Setter Property="CaretBrush"         Value="{StaticResource BrAccent}"/>
            <Setter Property="SelectionBrush"     Value="{StaticResource BrAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             COMBOBOX — full dark template
             ═══════════════════════════════════════════════════════════ -->

        <!-- ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="FontFamily"          Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"            Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Foreground"          Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="Background"          Value="Transparent"/>
            <Setter Property="Padding"             Value="12,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="4,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource BrBgElevated}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#2A1F4A"/>
                                <Setter Property="Foreground" Value="{StaticResource BrAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily"          Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"            Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Foreground"          Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="Background"          Value="{StaticResource BrBgElevated}"/>
            <Setter Property="BorderBrush"         Value="{StaticResource BrBorderSubtle}"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="Padding"             Value="12,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Main box -->
                            <Border x:Name="MainBd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusMedium}">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Selected item text -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"/>
                                    <!-- Chevron arrow -->
                                    <Path Grid.Column="1"
                                          Data="M 0,0 L 5,5 L 10,0"
                                          Stroke="{StaticResource BrTextSecondary}"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <!-- Transparent toggle button — NO hover effect, just opens the dropdown -->
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          OverridesDefaultStyle="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource BrBgSurface}"
                                        BorderBrush="{StaticResource BrBorderDefault}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="0,4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Effect="{x:Null}">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBd" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBd" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                                <Setter TargetName="MainBd" Property="Background"  Value="{StaticResource BrBgSurface}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             CHECKBOX — full dark template
             ═══════════════════════════════════════════════════════════ -->
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily"          Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"            Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Foreground"          Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- The box -->
                            <Border x:Name="CheckBd"
                                    Width="18" Height="18"
                                    Background="{StaticResource BrBgElevated}"
                                    BorderBrush="{StaticResource BrBorderDefault}"
                                    BorderThickness="1.5"
                                    CornerRadius="5"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <!-- Checkmark -->
                                <Path x:Name="CheckMark"
                                      Data="M 2,7 L 7,12 L 15,3"
                                      Stroke="{StaticResource BrAccent}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                            </Border>
                            <!-- Label -->
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBd"   Property="Background"   Value="#2A1F4A"/>
                                <Setter TargetName="CheckBd"   Property="BorderBrush"  Value="{StaticResource BrAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBd" Property="BorderBrush" Value="{StaticResource BrAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             LISTBOX  (transparent, no selection highlight)
             ═══════════════════════════════════════════════════════════ -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSizeBody}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             SCROLLBAR — thin, modern, no arrows
             ═══════════════════════════════════════════════════════════ -->

        <!-- Thumb (the draggable part) -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle"  Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBd"
                                Background="#3A3A58"
                                CornerRadius="3"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="#5A5A80"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="{StaticResource BrAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical ScrollBar template -->
        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid>
                <Border Background="#1A1A2A"
                        CornerRadius="3"
                        Width="8"
                        HorizontalAlignment="Center"/>
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True"
                       Width="8"
                       HorizontalAlignment="Center">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineUpCommand"
                                      Opacity="0"
                                      Height="0"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}"
                               MinHeight="20"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineDownCommand"
                                      Opacity="0"
                                      Height="0"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Horizontal ScrollBar template -->
        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid>
                <Border Background="#1A1A2A"
                        CornerRadius="3"
                        Height="8"
                        VerticalAlignment="Center"/>
                <Track x:Name="PART_Track"
                       IsDirectionReversed="False"
                       Height="8"
                       VerticalAlignment="Center">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineLeftCommand"
                                      Opacity="0"
                                      Width="0"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumbStyle}"
                               MinWidth="20"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineRightCommand"
                                      Opacity="0"
                                      Width="0"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Global ScrollBar style — picks the right template by orientation -->
        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Setter Property="OverridesDefaultStyle"  Value="True"/>
            <Setter Property="Width"  Value="8"/>
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"   Value="8"/>
                    <Setter Property="Width"    Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             HYPERLINK
             ═══════════════════════════════════════════════════════════ -->
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource BrAccent}"/>
            <Setter Property="TextDecorations" Value="None"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             STATUSBAR
             ═══════════════════════════════════════════════════════════ -->
        <Style TargetType="StatusBar">
            <Setter Property="Background"  Value="{StaticResource BrBgDeep}"/>
            <Setter Property="Foreground"  Value="{StaticResource BrTextSecondary}"/>
            <Setter Property="FontFamily"  Value="{StaticResource FontPrimary}"/>
            <Setter Property="FontSize"    Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="StatusBarItem">
            <Setter Property="Foreground" Value="{StaticResource BrTextSecondary}"/>
        </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

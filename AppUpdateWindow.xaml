<Window x:Class="OptiscalerManager.AppUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource TxtActualizacionTitle}"
        Height="420" Width="520"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="assets/icon.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BrBgSurface}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE895;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                           Foreground="{StaticResource BrAccentWarm}"
                           FontSize="24"
                           Margin="0,0,14,0"/>
                <StackPanel>
                    <TextBlock x:Name="TxtTitle"
                               Text="{DynamicResource TxtActualizacionTitle}"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrTextPrimary}"/>
                    <TextBlock x:Name="TxtVersion"
                               Text="v?.?.?"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource BrAccent}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <StackPanel x:Name="PanelInfo">
                <TextBlock Text="Release Notes"
                           Foreground="{StaticResource BrTextSecondary}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                
                <Border Background="{StaticResource BrBgCard}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLarge}"
                        Padding="20,16"
                        Height="180">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0">
                        <TextBlock x:Name="TxtReleaseNotes"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource BrTextPrimary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   LineHeight="20"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <StackPanel x:Name="PanelDownloading" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <TextBlock x:Name="TxtDownloadStatus" 
                           Text="Downloading update..." 
                           Foreground="{StaticResource BrTextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           FontWeight="SemiBold"
                           FontSize="{StaticResource FontSizeBodyLarge}"/>
                <Border Height="8" Margin="40,0" Background="{StaticResource BrBgElevated}" CornerRadius="4" ClipToBounds="True">
                     <ProgressBar x:Name="ProgDownload" 
                                  Minimum="0" Maximum="100"
                                  Background="Transparent"
                                  Foreground="{StaticResource BrAccent}"
                                  BorderThickness="0"/>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnSkip"
                        Content="{DynamicResource TxtBtnLater}"
                        Style="{StaticResource BtnBase}"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Click="BtnSkip_Click"/>
                <Button x:Name="BtnUpdate"
                        Content="{DynamicResource TxtBtnUpdate}"
                        Style="{StaticResource BtnPrimary}"
                        Padding="24,8"
                        Click="BtnUpdate_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="OptiscalerManager.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Height="240" Width="440"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="assets/icon.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE7A7;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                           Foreground="{StaticResource BrAccentWarm}"
                           FontSize="22"
                           Margin="0,0,14,0"/>
                <TextBlock x:Name="TxtTitle"
                           Text="Confirm"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrTextPrimary}"/>
            </StackPanel>
        </Border>

        <!-- Message -->
        <TextBlock x:Name="TxtMessage"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource BrTextPrimary}"
                   FontSize="{StaticResource FontSizeBody}"
                   Margin="24,20"/>

        <!-- Action Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel"
                        Content="{DynamicResource TxtCancel}"
                        Style="{StaticResource BtnBase}"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnConfirm"
                        Content="{DynamicResource TxtConfirmBtn}"
                        Style="{StaticResource BtnPrimary}"
                        Padding="24,8"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>

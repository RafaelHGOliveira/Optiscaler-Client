<Window x:Class="OptiscalerManager.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource TxtGuideTitle}"
        Height="600" Width="600"
        MinHeight="600" MinWidth="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="assets/icon.png">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="*"/>      <!-- content -->
            <RowDefinition Height="Auto"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BrBgSurface}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="{DynamicResource TxtGuideHeader}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrTextPrimary}"/>
                <TextBlock Text="{DynamicResource TxtGuideHeaderDesc}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource BrTextSecondary}"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Content ────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20" TextBlock.LineHeight="20">
                <Border Background="{StaticResource BrBgCard}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="16,12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource TxtGuideStep1Title}" FontWeight="SemiBold" Foreground="{StaticResource BrAccent}" Margin="0,0,0,8" />
                        <TextBlock Text="{DynamicResource TxtGuideStep1Desc}" TextWrapping="Wrap" Foreground="{StaticResource BrTextPrimary}" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BrBgCard}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="16,12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource TxtGuideStep2Title}" FontWeight="SemiBold" Foreground="{StaticResource BrAccent}" Margin="0,0,0,8" />
                        <TextBlock Text="{DynamicResource TxtGuideStep2Desc}" TextWrapping="Wrap" Foreground="{StaticResource BrTextPrimary}" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BrBgCard}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="16,12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource TxtGuideStep3Title}" FontWeight="SemiBold" Foreground="{StaticResource BrAccent}" Margin="0,0,0,8" />
                        <TextBlock Text="{DynamicResource TxtGuideStep3Desc}" TextWrapping="Wrap" Foreground="{StaticResource BrTextPrimary}" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BrBgCard}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource TxtGuideStep4Title}" FontWeight="SemiBold" Foreground="{StaticResource BrAccent}" Margin="0,0,0,8" />
                        <TextBlock Text="{DynamicResource TxtGuideStep4Desc}" TextWrapping="Wrap" Foreground="{StaticResource BrTextPrimary}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- ── Footer ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BrBgSurface}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Button Content="{DynamicResource TxtGotIt}"
                    x:Name="BtnClose"
                    Click="BtnClose_Click"
                    Style="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Right"
                    Width="100"/>
        </Border>
    </Grid>
</Window>

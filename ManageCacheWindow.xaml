<Window x:Class="OptiscalerManager.ManageCacheWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource TxtManageCacheTitle}"
        Height="450" Width="420"
        MinHeight="400" MinWidth="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="assets/icon.png">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BrBgSurface}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="{DynamicResource TxtLocalVersions}" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource TxtManageCacheDesc}"
                           FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextSecondary}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="{DynamicResource TxtDownloadedVersions}"
                   Foreground="{StaticResource BrTextSecondary}"
                   FontWeight="SemiBold"
                   Margin="24,20,24,0"/>

        <ScrollViewer Grid.Row="2" Margin="24,10,24,10" VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="LstCacheVersions" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BrBgSurface}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="16,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Text="v" Foreground="{StaticResource BrTextSecondary}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1"
                                        Content="{DynamicResource TxtDeleteIcon}"
                                        Style="{StaticResource BtnDanger}"
                                        Padding="12,4"
                                        Tag="{Binding}"
                                        Click="BtnDeleteVersion_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
        
        <TextBlock x:Name="TxtNoVersions" Grid.Row="2" Text="{DynamicResource TxtNoVersions}"
                   Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

        <!-- ════════════════════════════════════════════════════════
             TOAST NOTIFICATION
             ════════════════════════════════════════════════════════ -->
        <Border x:Name="BdToast" 
                Grid.Row="2" Grid.RowSpan="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Background="{StaticResource BrBgElevated}"
                BorderBrush="{StaticResource BrAccent}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMedium}"
                Margin="0,0,0,80"
                Padding="16,10"
                Visibility="Collapsed"
                Panel.ZIndex="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✓" Foreground="{StaticResource BrAccent}" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtToastMessage" Text="{DynamicResource TxtToastSuccess}" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             DELETE CONFIRMATION MODAL
             ════════════════════════════════════════════════════════ -->
        <Grid x:Name="BdConfirmDelete" Grid.RowSpan="4" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="20">
            <Border Background="{StaticResource BrBgElevated}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusLarge}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="24,24,24,20"
                    MaxWidth="360">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="🗑️" Foreground="{StaticResource BrAccentWarm}" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TxtConfirmDelTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="TxtConfirmDeleteMessage"
                               Text="{DynamicResource TxtConfirmDelMsg}"
                               Foreground="{StaticResource BrTextSecondary}" FontSize="{StaticResource FontSizeBody}"
                               TextWrapping="Wrap" Margin="0,0,0,24"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnConfirmDeleteNo" Content="{DynamicResource TxtCancel}" Style="{StaticResource BtnBase}" Padding="16,8" Margin="0,0,10,0"/>
                        <Button x:Name="BtnConfirmDeleteYes" Content="{DynamicResource TxtDeletePlain}" Style="{StaticResource BtnDanger}" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource BrBgDeep}" BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="0,1,0,0" Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource TxtClose}" IsCancel="True" Style="{StaticResource BtnBase}" Padding="16,8"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

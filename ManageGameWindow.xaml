<Window x:Class="OptiscalerManager.ManageGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptiscalerManager"
        xmlns:converters="clr-namespace:OptiscalerManager.Converters"
        mc:Ignorable="d"
        Title="{DynamicResource TxtManageGameWindow}"
        Height="480" Width="900"
        MinHeight="440" MinWidth="700"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="assets/icon.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter  x:Key="NullToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter  x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header with game info -->
            <RowDefinition Height="Auto"/>   <!-- Status card -->
            <RowDefinition Height="*"/>      <!-- Detected components -->
            <RowDefinition Height="Auto"/>   <!-- Progress bar -->
            <RowDefinition Height="Auto"/>   <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════
             HEADER
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtGameName"
                               Text="Game Name"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrTextPrimary}"/>
                    <TextBlock x:Name="TxtInstallPath"
                               Text=""
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource BrTextSecondary}"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button x:Name="BtnOpenFolder"
                        Grid.Column="1"
                        Content="{DynamicResource TxtOpenFolder}"
                        Style="{StaticResource BtnBase}"
                        Padding="12,7"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             STATUS CARD
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BrBgCard}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLarge}"
                Margin="24,20,24,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator + text -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator"
                             Width="10" Height="10"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource TxtOptiStatus}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource BrTextSecondary}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtStatus"
                                       Text="Not Installed"
                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrTextPrimary}"/>
                            <TextBlock x:Name="TxtVersion"
                                       Text=""
                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                       Foreground="{StaticResource BrTextSecondary}"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             DETECTED COMPONENTS
             ════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="2" Margin="24,20,24,0">
            <TextBlock Text="{DynamicResource TxtDetectedComponents}"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrTextSecondary}"
                       Margin="0,0,0,10"/>
            <ListBox x:Name="LstComponents"
                     Background="Transparent"
                     BorderThickness="0"
                     IsHitTestVisible="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"    Value="0,3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground"  Value="{StaticResource BrTextSecondary}"/>
                        <Setter Property="FontSize"    Value="{StaticResource FontSizeBody}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </StackPanel>

        <!-- ════════════════════════════════════════════════════════
             INSTALL PROGRESS
             ════════════════════════════════════════════════════════ -->
        <Border x:Name="BdProgress" 
                Grid.Row="3"
                Background="{StaticResource BrBgCard}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLarge}"
                Margin="24,10,24,10"
                Padding="20,14"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="TxtProgressState" Text="Downloading OptiScaler..." 
                           Foreground="{StaticResource BrTextPrimary}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ProgressBar x:Name="PrgDownload" Height="8" Minimum="0" Maximum="100" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             TOAST NOTIFICATION
             ════════════════════════════════════════════════════════ -->
        <Border x:Name="BdToast" 
                Grid.Row="3" Grid.RowSpan="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Background="{StaticResource BrBgElevated}"
                BorderBrush="{StaticResource BrAccent}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMedium}"
                Margin="0,0,0,80"
                Padding="16,10"
                Visibility="Collapsed"
                Panel.ZIndex="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtToastIcon" Text="✓" Foreground="{StaticResource BrAccent}" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtToastMessage" Text="Success" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             UNINSTALL CONFIRMATION MODAL
             ════════════════════════════════════════════════════════ -->
        <Grid x:Name="BdConfirmUninstall" Grid.RowSpan="5" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="20">
            <Border Background="{StaticResource BrBgElevated}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusLarge}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="24,24,24,20"
                    MaxWidth="400">
                <StackPanel>
                    <!-- Warning Icon & Title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="⚠️" Foreground="{StaticResource BrAccentWarm}" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource TxtConfirmUninstallTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Message -->
                    <TextBlock Text="{DynamicResource TxtConfirmUninstallMsg}"
                               Foreground="{StaticResource BrTextSecondary}" FontSize="{StaticResource FontSizeBody}"
                               TextWrapping="Wrap" Margin="0,0,0,24"/>
                    
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnConfirmUninstallNo" Content="{DynamicResource TxtCancel}" Style="{StaticResource BtnBase}" Padding="16,8" Margin="0,0,10,0"/>
                        <Button x:Name="BtnConfirmUninstallYes" Content="{DynamicResource TxtUninstall}" Style="{StaticResource BtnDanger}" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════
             ACTION BAR
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Install options (injection method + component checkboxes) -->
                <StackPanel x:Name="PnlInstallOptions"
                            Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource TxtVersionLbl}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Width="65"/>
                        <ComboBox x:Name="CmbOptiVersion"
                                  Width="220"
                                  SelectedIndex="0"
                                  VerticalContentAlignment="Center" />
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource TxtInjectionLbl}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Width="65"/>
                    <ComboBox x:Name="CmbInjectionMethod"
                              Width="130"
                              SelectedIndex="0"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="dxgi.dll"     Tag="dxgi.dll"/>
                        <ComboBoxItem Content="winmm.dll"    Tag="winmm.dll"/>
                        <ComboBoxItem Content="d3d12.dll"    Tag="d3d12.dll"/>
                        <ComboBoxItem Content="dbghelp.dll"  Tag="dbghelp.dll"/>
                        <ComboBoxItem Content="version.dll"  Tag="version.dll"/>
                        <ComboBoxItem Content="wininet.dll"  Tag="wininet.dll"/>
                        <ComboBoxItem Content="winhttp.dll"  Tag="winhttp.dll"/>
                    </ComboBox>

                    <Border Width="1"
                            Background="{StaticResource BrBorderSubtle}"
                            Margin="16,4"/>

                    <CheckBox x:Name="ChkInstallFakenvapi"
                              Content="Fakenvapi"
                              Margin="0,0,16,0"
                              VerticalAlignment="Center"
                              ToolTip="{DynamicResource TxtFakenvapiTip}"/>
                    <CheckBox x:Name="ChkInstallNukemFG"
                              Content="NukemFG"
                              VerticalAlignment="Center"
                              ToolTip="{DynamicResource TxtNukemTip}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right-side action buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">

                    <!-- Install Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0" x:Name="InstallBtnGroup">
                        <Button x:Name="BtnInstallManual"
                                Content="{DynamicResource TxtBtnManualInstall}"
                                Style="{StaticResource BtnSuccess}"
                                Padding="18,8"
                                Margin="0,0,10,0"/>

                        <Button x:Name="BtnInstall"
                                Content="{DynamicResource TxtInstallOpti}"
                                Style="{StaticResource BtnSuccess}"
                                Padding="18,8"/>
                    </StackPanel>

                    <Button x:Name="BtnUninstall"
                            Content="{DynamicResource TxtUninstall}"
                            Style="{StaticResource BtnDanger}"
                            Padding="18,8"
                            Margin="0,0,0,0"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>

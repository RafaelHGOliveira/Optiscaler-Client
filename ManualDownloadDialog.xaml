<Window x:Class="OptiscalerManager.ManualDownloadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource TxtManualTitle}"
        Height="460" Width="680"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="assets/icon.png"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Instructions card -->
            <RowDefinition Height="Auto"/>   <!-- File picker -->
            <RowDefinition Height="Auto"/>   <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════
             HEADER
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock x:Name="TxtTitle"
                           Text="{DynamicResource TxtManualTitle}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrTextPrimary}"/>
                <TextBlock x:Name="TxtComponentName"
                           Text="NukemFG"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource BrAccentWarm}"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             INSTRUCTIONS CARD
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BrBgCard}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLarge}"
                Margin="24,20,24,0"
                Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="TxtMainInstruction"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource BrTextPrimary}"
                           FontSize="{StaticResource FontSizeBody}"
                           Margin="0,0,0,12"/>

                <!-- Download link -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource TxtDownloadFrom}"
                               Foreground="{StaticResource BrTextSecondary}"
                               FontSize="{StaticResource FontSizeBody}"
                               VerticalAlignment="Center"/>
                    <TextBlock FontSize="{StaticResource FontSizeBody}">
                        <Hyperlink x:Name="LnkDownload"
                                   NavigateUri="https://www.nexusmods.com/site/mods/738?tab=files"
                                   RequestNavigate="LnkDownload_RequestNavigate">
                            <Run Text="Nexus Mods — dlssg-to-fsr3"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Required filename -->
                <Border Background="{StaticResource BrBgElevated}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSmall}"
                        Padding="10,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource TxtReqFileLbl}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   FontSize="{StaticResource FontSizeBody}"/>
                        <TextBlock x:Name="TxtRequiredFile"
                                   Text="dlssg_to_fsr3_amd_is_better.dll"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{StaticResource BrAccent}"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="TxtBrowseHint"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrAccentWarm}"
                           FontSize="{StaticResource FontSizeBody}"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             FILE PICKER
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="24,16,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSelectedPath"
                         Grid.Column="0"
                         IsReadOnly="True"
                         Margin="0,0,10,0"
                         Padding="10,8"
                         Foreground="{StaticResource BrTextSecondary}"/>
                <Button x:Name="BtnBrowse"
                        Grid.Column="1"
                        Content="{DynamicResource TxtBrowse}"
                        Style="{StaticResource BtnBase}"
                        Padding="14,8"
                        Click="BtnBrowse_Click"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             ACTION BAR
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource BrBgDeep}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="24,14"
                Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnSkip"
                        Content="Cancel"
                        Style="{StaticResource BtnBase}"
                        Padding="16,8"
                        Margin="0,0,10,0"
                        Click="BtnSkip_Click"/>
                <Button x:Name="BtnConfirm"
                        Content="{DynamicResource TxtConfirmBtn}"
                        Style="{StaticResource BtnPrimary}"
                        Padding="18,8"
                        IsEnabled="False"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptiscalerClient"
        xmlns:converters="clr-namespace:OptiscalerClient.Converters"
        xmlns:models="clr-namespace:OptiscalerClient.Models"
        mc:Ignorable="d"
        x:Class="OptiscalerClient.Views.BulkInstallWindow"
        Title="{DynamicResource TxtBulkInstallWindow}"
        Height="820" Width="900"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Window.Resources>

    <Panel Margin="15" Name="RootPanel" Opacity="0">
        <!-- Main Container with Shadow -->
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 8 32 0 #80000000"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header -->
                    <RowDefinition Height="Auto"/>   <!-- Select All + Search -->
                    <RowDefinition Height="*"/>      <!-- Main Content -->
                </Grid.RowDefinitions>

                <!-- ════════════════════════════════════════════════════════
                     HEADER / TITLE BAR
                     ════════════════════════════════════════════════════════ -->
                <Border Grid.Row="0"
                        Name="TitleBar"
                        Background="{StaticResource BrBgDeep}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0"
                        Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource TxtBulkInstallWindow}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Name="BtnClose"
                                Content="✕"
                                Classes="BtnBase"
                                Padding="10,5"
                                Click="BtnClose_Click"/>
                    </Grid>
                </Border>

                <!-- ════════════════════════════════════════════════════════
                     SELECT ALL + SEARCH BAR
                     ════════════════════════════════════════════════════════ -->
                <Border Grid.Row="1"
                        Background="{StaticResource BrBgSurface}"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  Name="ChkSelectAll"
                                  Content="{DynamicResource TxtSelectAll}"
                                  FontWeight="Medium"
                                  Foreground="{StaticResource BrTextPrimary}"
                                  FontSize="12"
                                  Click="ChkSelectAll_Click"/>

                        <TextBox Grid.Column="1"
                                 Name="TxtSearch"
                                 Width="340"
                                 Height="28"
                                 Classes="BtnBase"
                                 Padding="8,4"
                                 FontSize="12"
                                 Watermark="{DynamicResource TxtSearchGames}"
                                 TextChanged="TxtSearch_TextChanged"
                                 LostFocus="TxtSearch_LostFocus"
                                 Margin="16,0,0,0"
                                 VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                                   Name="TxtSelectionCount"
                                   Text="0 games selected"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ════════════════════════════════════════════════════════
                     MAIN CONTENT: SIDEBAR + GAMES LIST
                     ════════════════════════════════════════════════════════ -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="270"/>  <!-- Left Sidebar -->
                        <ColumnDefinition Width="*"/>    <!-- Games List -->
                    </Grid.ColumnDefinitions>

                    <!-- ────────────────────────────────────────────────────
                         LEFT SIDEBAR (Settings + Progress + Actions)
                         ──────────────────────────────────────────────────── -->
                    <Border Grid.Column="0"
                            Background="{StaticResource BrBgSurface}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="0,0,1,0"
                            CornerRadius="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- Settings -->
                                <RowDefinition Height="*"/>      <!-- Spacer -->
                                <RowDefinition Height="Auto"/>   <!-- Progress -->
                                <RowDefinition Height="Auto"/>   <!-- Action buttons -->
                            </Grid.RowDefinitions>

                            <!-- Installation Settings -->
                            <StackPanel Grid.Row="0" Margin="16,20,16,4" Spacing="14">
                                <TextBlock Text="{DynamicResource TxtInstallationSettings}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrTextPrimary}"/>

                                <!-- Version -->
                                <StackPanel Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource TxtVersion}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource BrBgElevated}"
                                                BorderBrush="{StaticResource BrBorderSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Width="14" Height="14"
                                                ToolTip.ShowDelay="100" Cursor="Help"
                                                ToolTip.Tip="{DynamicResource TxtTooltipOptiScalerVersion}">
                                            <TextBlock Text="?" Foreground="{StaticResource BrTextSecondary}"
                                                       FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="0,-1,0,0"/>
                                        </Border>
                                    </StackPanel>
                                    <ComboBox Name="CmbOptiVersion"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              Background="{StaticResource BrBgBase}"
                                              Foreground="{StaticResource BrTextPrimary}"
                                              BorderBrush="{StaticResource BrBorderSubtle}"/>
                                </StackPanel>

                                <!-- Injection Method -->
                                <StackPanel Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource TxtInjectionLbl}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource BrBgElevated}"
                                                BorderBrush="{StaticResource BrBorderSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Width="14" Height="14"
                                                ToolTip.ShowDelay="100" Cursor="Help"
                                                ToolTip.Tip="{DynamicResource TxtTooltipInjectionMethod}">
                                            <TextBlock Text="?" Foreground="{StaticResource BrTextSecondary}"
                                                       FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="0,-1,0,0"/>
                                        </Border>
                                    </StackPanel>
                                    <ComboBox Name="CmbInjectionMethod"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              SelectedIndex="0"
                                              Background="{StaticResource BrBgBase}"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="dxgi.dll"     Tag="dxgi.dll"/>
                                        <ComboBoxItem Content="winmm.dll"    Tag="winmm.dll"/>
                                        <ComboBoxItem Content="d3d12.dll"    Tag="d3d12.dll"/>
                                        <ComboBoxItem Content="dbghelp.dll"  Tag="dbghelp.dll"/>
                                        <ComboBoxItem Content="version.dll"  Tag="version.dll"/>
                                        <ComboBoxItem Content="wininet.dll"  Tag="wininet.dll"/>
                                        <ComboBoxItem Content="winhttp.dll"  Tag="winhttp.dll"/>
                                        <ComboBoxItem Content="OptiScaler.asi"    Tag="OptiScaler.asi"/>
                                        <ComboBoxItem Content="dlss-enabler.dll"  Tag="dlss-enabler.dll"/>
                                        <ComboBoxItem Content="dinput8.dll"       Tag="dinput8.dll"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- FSR4 INT8 -->
                                <StackPanel Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="FSR4 INT8:"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource BrBgElevated}"
                                                BorderBrush="{StaticResource BrBorderSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Width="14" Height="14"
                                                ToolTip.ShowDelay="100" Cursor="Help"
                                                ToolTip.Tip="{DynamicResource TxtTooltipFsr4Int8}">
                                            <TextBlock Text="?" Foreground="{StaticResource BrTextSecondary}"
                                                       FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="0,-1,0,0"/>
                                        </Border>
                                    </StackPanel>
                                    <ComboBox Name="CmbExtrasVersion"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              Padding="8,0,24,0"
                                              HorizontalContentAlignment="Left"
                                              Background="{StaticResource BrBgBase}"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- OptiPatcher -->
                                <StackPanel Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource TxtOptiPatcherLbl}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource BrBgElevated}"
                                                BorderBrush="{StaticResource BrBorderSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Width="14" Height="14"
                                                ToolTip.ShowDelay="100" Cursor="Help"
                                                ToolTip.Tip="{DynamicResource TxtOptiPatcherTooltip}">
                                            <TextBlock Text="?" Foreground="{StaticResource BrTextSecondary}"
                                                       FontSize="9" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="0,-1,0,0"/>
                                        </Border>
                                    </StackPanel>
                                    <ComboBox Name="CmbOptiPatcherVersion"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              HorizontalContentAlignment="Left"
                                              Background="{StaticResource BrBgBase}"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Profile -->
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Profile"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               FontSize="12"/>
                                    <ComboBox Name="CmbProfile"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              HorizontalContentAlignment="Left"
                                              Background="{StaticResource BrBgBase}"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Height="1" Background="{StaticResource BrBorderSubtle}" Margin="0,2"/>

                                <!-- Fakenvapi -->
                                <CheckBox Name="ChkFakenvapi"
                                          Content="{DynamicResource TxtInstallFakenvapi}"
                                          Foreground="{StaticResource BrTextPrimary}"
                                          FontSize="12"/>

                                <!-- NukemFG -->
                                <CheckBox Name="ChkNukemFG"
                                          Content="{DynamicResource TxtInstallNukemFG}"
                                          Foreground="{StaticResource BrTextPrimary}"
                                          FontSize="12"/>
                            </StackPanel>

                            <!-- Progress Bar -->
                            <Border Grid.Row="2"
                                    Name="ProgressSection"
                                    Background="{StaticResource BrBgDeep}"
                                    BorderBrush="{StaticResource BrBorderSubtle}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,12"
                                    IsVisible="False">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Name="TxtProgressStatus"
                                                   Text="Installing..."
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrTextPrimary}"/>
                                        <TextBlock Name="TxtProgressCount"
                                                   Text="1 / 5"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{StaticResource BrTextSecondary}"/>
                                    </Grid>
                                    <ProgressBar Name="ProgressBar"
                                                 Height="6"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"
                                                 Background="{StaticResource BrBgBase}"
                                                 Foreground="{StaticResource BrAccent}"/>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <Border Grid.Row="3"
                                    Background="{StaticResource BrBgDeep}"
                                    BorderBrush="{StaticResource BrBorderSubtle}"
                                    BorderThickness="0,1,0,0"
                                    CornerRadius="0,0,0,12"
                                    Padding="16,12">
                                <StackPanel Spacing="8">
                                    <Button Name="BtnInstall"
                                            Content="{DynamicResource TxtInstallSelected}"
                                            Classes="BtnBase BtnPrimary"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="16,8"
                                            Click="BtnInstall_Click"/>
                                    <Button Name="BtnCancel"
                                            Content="{DynamicResource TxtCancel}"
                                            Classes="BtnBase"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="12,8"
                                            Click="BtnCancel_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ────────────────────────────────────────────────────
                         GAMES LIST (Scrollable)
                         ──────────────────────────────────────────────────── -->
                    <ScrollViewer Grid.Column="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0">
                        <ItemsControl Name="GamesList" Padding="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BrBgSurface}"
                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,6"
                                            Margin="12,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding CanInstall}"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"/>

                                            <Image Grid.Column="1"
                                                   Source="{Binding CoverPath}"
                                                   Width="28"
                                                   Height="42"
                                                   Stretch="UniformToFill"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center">
                                                <Image.Clip>
                                                    <RectangleGeometry Rect="0,0,28,42" RadiusX="3" RadiusY="3"/>
                                                </Image.Clip>
                                            </Image>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Medium"
                                                           Foreground="{StaticResource BrTextPrimary}"
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding Platform}"
                                                           Foreground="{StaticResource BrTextSecondary}"
                                                           FontSize="10"
                                                           Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                                                <!-- OptiScaler badge (violet) -->
                                                <Border Background="#1E1530"
                                                        BorderBrush="{StaticResource BrAccent}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="6,2"
                                                        IsVisible="{Binding IsOptiscalerInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="✦ OptiScaler"
                                                                   Foreground="{StaticResource BrAccent}"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding OptiscalerVersion, StringFormat=' {0}'}"
                                                                   Foreground="{StaticResource BrAccent}"
                                                                   FontSize="8"
                                                                   FontWeight="SemiBold"
                                                                   IsVisible="{Binding OptiscalerVersion, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Installed badge -->
                                                <Border Background="{StaticResource BrBgDeep}"
                                                        CornerRadius="3"
                                                        Padding="6,2"
                                                        IsVisible="{Binding IsInstalled}">
                                                    <TextBlock Text="{DynamicResource TxtInstalled}"
                                                               FontSize="9"
                                                               FontWeight="Medium"
                                                               Foreground="{StaticResource BrTextSecondary}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Panel>
</Window>

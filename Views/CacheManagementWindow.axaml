<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.CacheManagementWindow"
        Title="Cache Management"
        Width="500"
        Height="640"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False">

    <Panel Margin="16" Name="RootPanel" Opacity="0">
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 10 30 0 #A0000000">
            
            <Grid>
                <!-- Separate layer for the subtle border -->
                <Border CornerRadius="12"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        ZIndex="10"
                        IsHitTestVisible="False"/>

                <!-- Main Content Layout -->
                <Border CornerRadius="12"
                        Background="Transparent"
                        ClipToBounds="True">
                    
                    <Grid RowDefinitions="Auto, *, Auto">
                        <!-- Custom Title Bar (Draggable) -->
                        <Border Grid.Row="0"
                                Name="TitleBar"
                                Background="{StaticResource BrBgDeep}"
                                Padding="24,18"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource TxtManageCacheTitle}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtManageCacheDesc}"
                                               FontSize="11"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Classes="BtnSecondary"
                                        Padding="8,4"
                                        MinWidth="32"
                                        FontSize="14"
                                        Click="BtnClose_Click"
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        BorderThickness="0"/>
                            </Grid>
                        </Border>

                        <!-- List of downloaded versions -->
                        <ScrollViewer Grid.Row="1" Padding="0">
                            <StackPanel Spacing="0" Margin="24,20">
                                <!-- Group 1: OptiScaler -->
                                <TextBlock Text="OptiScaler Versions" 
                                           FontWeight="SemiBold" 
                                           FontSize="13" 
                                           Foreground="{StaticResource BrTextSecondary}"
                                           Margin="0,0,0,12"/>
                                <StackPanel Name="PnlVersions" Spacing="8" Margin="0,0,0,24">
                                    <!-- OptiScaler versions go here -->
                                </StackPanel>

                                <!-- Group 2: FSR 4 INT8 Extras -->
                                <TextBlock Text="FSR4 INT8 (Injection DLLs)" 
                                           FontWeight="SemiBold" 
                                           FontSize="13" 
                                           Foreground="{StaticResource BrTextSecondary}"
                                           Margin="0,0,0,12"/>
                                <StackPanel Name="PnlExtrasVersions" Spacing="8">
                                    <!-- Extras versions go here -->
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="2"
                                Padding="24,18"
                                Background="{StaticResource BrBgDeep}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Grid.Column="0" 
                                           Name="TxtCacheInfo"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{StaticResource BrTextSecondary}"/>
                                <Button Grid.Column="1"
                                        Content="{DynamicResource TxtClose}"
                                        Classes="BtnPrimary"
                                        Padding="20,8"
                                        Click="BtnClose_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>
</Window>

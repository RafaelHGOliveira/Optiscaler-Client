<Window x:Class="OptiscalerClient.Views.ComponentInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource TxtComponentTitle}"
        Height="460" Width="420"
        MinHeight="410" MinWidth="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="/Assets/icon.png">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="*"/>      <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BrBgSurface}"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource TxtComponentTitle}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrTextPrimary}"/>
                    <TextBlock Text="{DynamicResource TxtComponentDesc}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource BrTextSecondary}"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{DynamicResource TxtBtnGuide}"
                        x:Name="BtnGuide"
                        Click="BtnGuide_Click"
                        Style="{StaticResource BtnBase}"
                        Padding="12,6"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Component rows ──────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Margin="24,20">

            <!-- OptiScaler -->
            <Border Background="{StaticResource BrBgSurface}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Padding="16,8"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="OptiScaler"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BdOptiUpdate"
                                Background="#2A1F4A"
                                BorderBrush="{StaticResource BrAccent}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource TxtUpdateAvail}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrAccent}"/>
                        </Border>
                        
                        <TextBlock x:Name="TxtOptiVersion"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrAccent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Fakenvapi -->
            <Border Background="{StaticResource BrBgSurface}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Padding="16,8"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Fakenvapi"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BdFakeUpdate"
                                Background="#2A1F4A"
                                BorderBrush="{StaticResource BrAccent}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource TxtUpdateAvail}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrAccent}"/>
                        </Border>
                        
                        <TextBlock x:Name="TxtFakeVersion"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrAccent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- NukemFG -->
            <Border Background="{StaticResource BrBgSurface}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="NukemFG"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BdNukemUpdate"
                                Background="#3D2410"
                                BorderBrush="{StaticResource BrAccentWarm}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8,4"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource TxtUpdateAvail}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrAccentWarm}"/>
                        </Border>
                        
                        <TextBlock x:Name="TxtNukemVersion"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrAccentWarm}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- App Version -->
            <Border Background="{StaticResource BrBgCard}"
                    BorderBrush="{StaticResource BrBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMedium}"
                    Padding="16,8"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Optiscaler Client"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrTextPrimary}"/>
                        <TextBlock Text="{DynamicResource TxtAppVersionLbl}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="v1.0.1"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrAccent}"
                                   VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </Grid>
</Window>

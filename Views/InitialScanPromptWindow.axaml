<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.InitialScanPromptWindow"
        Title="Initial Scan"
        Width="560"
        Height="720"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False">

    <Panel Margin="16" Name="RootPanel" Opacity="0">
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 10 30 0 #A0000000">
            <Grid>
                <Border CornerRadius="12"
                        BorderBrush="{StaticResource BrBorderSubtle}"
                        BorderThickness="1"
                        ZIndex="10"
                        IsHitTestVisible="False"/>

                <Border CornerRadius="12"
                        Background="Transparent"
                        ClipToBounds="True">
                    <Grid RowDefinitions="Auto,*,Auto">

                        <!-- Title Bar -->
                        <Border Grid.Row="0"
                                Name="TitleBar"
                                Background="{StaticResource BrBgDeep}"
                                Padding="24,18"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Name="TxtTitle"
                                           Text="{DynamicResource TxtInitialScanTitle}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BrTextPrimary}"/>
                                <TextBlock Name="TxtDesc"
                                           Text="{DynamicResource TxtInitialScanDesc}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource BrTextSecondary}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="24,20">

                                <!-- Refresh missing covers only -->
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrAccent}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12"
                                        Margin="0,0,0,20">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Refresh missing covers only"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrTextPrimary}"/>
                                            <TextBlock Text="Skip the full scan and only retry cover art for games that couldn't be fetched before. Useful after setting up a SteamGridDB API key."
                                                       Foreground="{StaticResource BrTextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,16,0"
                                                       FontSize="{StaticResource FontSizeCaption}"/>
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      Name="TglRefreshCoversOnly"
                                                      OnContent="" OffContent=""
                                                      IsChecked="False"
                                                      IsCheckedChanged="TglRefreshCoversOnly_IsCheckedChanged"/>
                                    </Grid>
                                </Border>

                                <!-- Scan options panel (disabled when covers-only is active) -->
                                <StackPanel Name="PnlScanOptions">

                                <TextBlock Text="{DynamicResource TxtInitialScanDrives}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           Margin="0,0,0,12"/>

                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12"
                                        Margin="0,0,0,24">
                                    <StackPanel Name="PnlDriveList" Spacing="12">
                                        <TextBlock Name="TxtNoDrives"
                                                   Text="{DynamicResource TxtInitialScanNoDrives}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   IsVisible="False"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{DynamicResource TxtInitialScanSources}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           Margin="0,0,0,12"/>

                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="16,12">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Steam" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglSteam" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Epic Games" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglEpic" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="GOG Galaxy" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglGOG" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Xbox (Microsoft Store)" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglXbox" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="EA App" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglEA" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="Ubisoft Connect" VerticalAlignment="Center" Foreground="{StaticResource BrTextPrimary}"/>
                                            <ToggleSwitch Grid.Column="1" Name="TglUbisoft" OnContent="" OffContent="" IsChecked="True"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                </StackPanel> <!-- /PnlScanOptions -->

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer Buttons -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BrBgDeep}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="0,1,0,0"
                                Padding="24,16">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                <Button Content="{DynamicResource TxtInitialScanClose}"
                                        Classes="BtnSecondary"
                                        Padding="20,10"
                                        Click="BtnClose_Click"/>
                                <Button Content="{DynamicResource TxtInitialScanStart}"
                                        Classes="BtnPrimary"
                                        Padding="20,10"
                                        Click="BtnStartScan_Click"/>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Panel>
</Window>

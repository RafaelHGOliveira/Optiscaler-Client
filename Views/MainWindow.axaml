<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptiscalerClient"
        xmlns:converters="clr-namespace:OptiscalerClient.Converters"
        xmlns:models="clr-namespace:OptiscalerClient.Models"
        mc:Ignorable="d"
        x:Class="OptiscalerClient.Views.MainWindow"
        Title="{DynamicResource TxtAppTitle}"
        Height="720" Width="1280"
        MinHeight="520" MinWidth="760"
        Background="{StaticResource BrBgBase}"
        Foreground="{StaticResource BrTextPrimary}"
        FontFamily="{StaticResource FontPrimary}"
        Icon="avares://OptiscalerClient/assets/icon.png">

    <Window.Resources>
        <converters:NullToVisibilityConverter  x:Key="NullToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibilityConverter"/>
        <converters:BitmapValueConverter       x:Key="BitmapValueConverter"/>


        </Window.Resources>

    <Window.Styles>
        <Style Selector="RadioButton.NavBtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <Grid>
                            <Border Name="Indicator" Width="3" Height="24" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{StaticResource BrAccent}" IsVisible="False" CornerRadius="1.5" Margin="2,0,0,0"/>
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="{TemplateBinding ToolTip.Tip}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.NavBtnStyle:checked /template/ Border#Indicator">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="RadioButton.NavBtnStyle:checked">
            <Setter Property="Foreground" Value="{StaticResource BrAccent}"/>
            <Setter Property="Background" Value="{StaticResource BrBgElevated}"/>
        </Style>
        <Style Selector="RadioButton.NavBtnStyle:pointerover">
            <Setter Property="Foreground" Value="{StaticResource BrTextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource BrBgCard}"/>
        </Style>

        <!-- Organize mode: hide action buttons, show edit controls via ListBox class -->
        <Style Selector="ListBox#LstGames ListBoxItem StackPanel.EditModePanel">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ListBox#LstGames.EditMode ListBoxItem StackPanel.EditModePanel">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="ListBox#LstGames.EditMode ListBoxItem Button.NormalModeAction">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <!-- Grid organize mode overlay -->
        <Style Selector="ListBox#LstGamesGrid ListBoxItem Border.GridEditOverlay">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ListBox#LstGamesGrid.EditMode ListBoxItem Border.GridEditOverlay">
            <Setter Property="IsVisible" Value="True"/>
        </Style>

        <!-- Scan modal dot bounce animations (animate Margin via built-in ThicknessAnimator) -->
        <Style Selector="Ellipse#ScanDot1">
            <Style.Animations>
                <Animation Duration="0:0:0.6" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Margin" Value="4,12,4,0"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Margin" Value="4,2,4,10"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Margin" Value="4,12,4,0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse#ScanDot2">
            <Style.Animations>
                <Animation Duration="0:0:0.6" Delay="0:0:0.2" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Margin" Value="4,12,4,0"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Margin" Value="4,2,4,10"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Margin" Value="4,12,4,0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Ellipse#ScanDot3">
            <Style.Animations>
                <Animation Duration="0:0:0.6" Delay="0:0:0.4" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Margin" Value="4,12,4,0"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Margin" Value="4,2,4,10"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Margin" Value="4,12,4,0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="68"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>  <!-- Main Content Area -->
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource BrBgDeep}" BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="0,0,1,0" ZIndex="10">
            <Grid Margin="0,16">
                <!-- Top actions: Logo + Games + Profiles -->
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Image Source="avares://OptiscalerClient/assets/icon.png" Width="32" Height="32" Margin="0,0,0,24" RenderOptions.BitmapInterpolationMode="HighQuality"/>

                    <RadioButton Name="NavGames" GroupName="SidebarNav" Classes="NavBtnStyle" Content="&#xE7FC;" ToolTip.Tip="Games" IsChecked="True" Click="NavGames_Click"/>
                    <RadioButton Name="NavProfiles" GroupName="SidebarNav" Classes="NavBtnStyle" Content="&#xE734;" ToolTip.Tip="Profiles" Click="NavProfiles_Click"/>
                </StackPanel>

                <!-- Bottom actions: Settings, Help -->
                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <RadioButton Name="NavHelp" GroupName="SidebarNav" Classes="NavBtnStyle" Content="&#xE897;" ToolTip.Tip="{DynamicResource TxtAboutTitle}" Click="NavHelp_Click"/>
                    <RadioButton Name="NavSettings" GroupName="SidebarNav" Classes="NavBtnStyle" Content="&#xE713;" ToolTip.Tip="{DynamicResource TxtSettingsTitle}" Click="NavSettings_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1">

             <!-- ════════════════════════════════════════════════════════
                  1. GAMES VIEW
                  ════════════════════════════════════════════════════════ -->
             <Grid Name="ViewGames">
                 <Grid.Transitions>
                     <Transitions>
                         <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                     </Transitions>
                 </Grid.Transitions>
                 <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="*"/>
                     <RowDefinition Height="Auto"/>
                 </Grid.RowDefinitions>

                 <!-- Header -->
                 <Border Grid.Row="0"
                         Background="{StaticResource BrBgDeep}"
                         BorderBrush="{StaticResource BrBorderSubtle}"
                         BorderThickness="0,0,0,1"
                         Padding="24,16">
                     <Grid>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="Auto"/>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>

                         <!-- Left: Title + action buttons -->
                         <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                             <!-- Action buttons -->
                             <Button Name="BtnScan"
                                     Content="{DynamicResource TxtBtnScan}"
                                     Classes="BtnBase"
                                     Padding="14,7"
                                     Margin="0,0,10,0"
                                     Click="BtnScan_Click"/>

                             <Button Name="BtnAddManual"
                                     Content="{DynamicResource TxtBtnAddManual}"
                                     Classes="BtnBase"
                                     Padding="14,7"
                                     Margin="0,0,10,0"
                                     Click="BtnAddManual_Click"/>

                             <Button Name="BtnBulkInstall"
                                     Content="{DynamicResource TxtBtnBulkInstall}"
                                     Classes="BtnBase"
                                     Padding="14,7"
                                     Click="BtnBulkInstall_Click"/>
                         </StackPanel>

                         <!-- Middle: Search Bar -->
                         <Grid Grid.Column="1" Margin="32,0" MaxWidth="400" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                             <TextBox Name="TxtSearch"
                                      Padding="32,7,12,7"
                                      Background="{StaticResource BrBgSurface}"
                                      Foreground="{StaticResource BrTextPrimary}"
                                      BorderBrush="{StaticResource BrBorderSubtle}"
                                      BorderThickness="1"
                                      VerticalAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      GotFocus="TxtSearch_GotFocus"
                                      LostFocus="TxtSearch_LostFocus"
                                      TextChanged="TxtSearch_TextChanged">
                                 <TextBox.Styles>
                                     <Style Selector="TextBox /template/ Border#PART_BorderElement">
                                         <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
                                     </Style>
                                 </TextBox.Styles>
                             </TextBox>
                             <TextBlock IsHitTestVisible="False"
                                        Text="&#xE721;"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="12,0,0,0"
                                        FontSize="14"/>
                             <TextBlock Name="TxtSearchPlaceholder"
                                        IsHitTestVisible="False"
                                        Text="{DynamicResource TxtSearchGames}"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="34,0,0,0"/>
                         </Grid>

                         <!-- Right: GPU chip + Nukem updates -->
                         <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                             <Border Background="{StaticResource BrBgSurface}"
                                     BorderBrush="{StaticResource BrBorderSubtle}"
                                     BorderThickness="1"
                                     CornerRadius="{StaticResource RadiusMedium}"
                                     Padding="4"
                                     Margin="0,0,10,0">
                                 <StackPanel Orientation="Horizontal" Spacing="4">
                                     <Button Name="BtnViewList"
                                             Width="32"
                                             Height="28"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource BrTextPrimary}"
                                             ToolTip.Tip="{DynamicResource TxtViewList}"
                                             Click="BtnViewList_Click">
                                         <Grid Width="14" Height="12" RowDefinitions="Auto,Auto,Auto">
                                             <Border Grid.Row="0" Height="2" CornerRadius="1" Background="{StaticResource BrTextPrimary}" Margin="0,0,0,3"/>
                                             <Border Grid.Row="1" Height="2" CornerRadius="1" Background="{StaticResource BrTextPrimary}" Margin="0,0,0,3"/>
                                             <Border Grid.Row="2" Height="2" CornerRadius="1" Background="{StaticResource BrTextPrimary}"/>
                                         </Grid>
                                     </Button>
                                     <Button Name="BtnViewGrid"
                                             Width="32"
                                             Height="28"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource BrTextPrimary}"
                                             ToolTip.Tip="{DynamicResource TxtViewGrid}"
                                             Click="BtnViewGrid_Click">
                                         <Grid Width="14" Height="14"
                                               ColumnDefinitions="Auto,Auto"
                                               RowDefinitions="Auto,Auto"
                                               ColumnSpacing="3"
                                               RowSpacing="3">
                                             <Border Grid.Row="0" Grid.Column="0" Width="5" Height="5" CornerRadius="1" Background="{StaticResource BrTextPrimary}"/>
                                             <Border Grid.Row="0" Grid.Column="1" Width="5" Height="5" CornerRadius="1" Background="{StaticResource BrTextPrimary}"/>
                                             <Border Grid.Row="1" Grid.Column="0" Width="5" Height="5" CornerRadius="1" Background="{StaticResource BrTextPrimary}"/>
                                             <Border Grid.Row="1" Grid.Column="1" Width="5" Height="5" CornerRadius="1" Background="{StaticResource BrTextPrimary}"/>
                                         </Grid>
                                     </Button>

                                     <!-- Separator -->
                                     <Border Width="1" Height="18" Background="{StaticResource BrBorderSubtle}" Margin="2,0"/>

                                     <!-- Edit / Organize mode -->
                                     <Button Name="BtnEditMode"
                                             Width="32"
                                             Height="28"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ToolTip.Tip="Organize games"
                                             Click="BtnEditMode_Click">
                                            <Grid Width="18" Height="18">
                                                <TextBlock Text="&#xE70F;"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                                           FontSize="14"
                                                           Foreground="{StaticResource BrTextPrimary}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Grid>
                                     </Button>
                                 </StackPanel>
                             </Border>

                             <Border Background="{StaticResource BrBgSurface}"
                                     BorderBrush="{StaticResource BrBorderSubtle}"
                                     BorderThickness="1"
                                     CornerRadius="{StaticResource RadiusMedium}"
                                     Padding="12,5" Margin="0,0,10,0">
                                 <TextBlock Name="TxtGpuInfo"
                                            FontSize="{StaticResource FontSizeCaption}"
                                            Foreground="{StaticResource BrTextSecondary}"
                                            VerticalAlignment="Center"/>
                             </Border>
                         </StackPanel>
                     </Grid>
                 </Border>

                 <!-- Edit Mode Banner -->
                 <Border Name="EditModeBanner"
                         Grid.Row="1"
                         IsVisible="False"
                         Background="#1A7C3AED"
                         BorderBrush="{StaticResource BrAccent}"
                         BorderThickness="0,0,0,1"
                         Padding="20,8">
                     <Grid>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>
                         <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                             <TextBlock Text="&#xE70F;"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                        FontSize="14"
                                        Foreground="{StaticResource BrAccent}"
                                        VerticalAlignment="Center"/>
                             <TextBlock Text="Organize Mode"
                                        Foreground="{StaticResource BrAccent}"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center"/>
                             <TextBlock Text="·"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        VerticalAlignment="Center"/>
                             <TextBlock Text="&#x25B2;&#x25BC; reorder"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        FontSize="11"
                                        VerticalAlignment="Center"/>
                             <TextBlock Text="·"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        VerticalAlignment="Center"/>
                             <TextBlock Text="&#xE7B3; hide/show"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        FontSize="11"
                                        VerticalAlignment="Center"/>
                         </StackPanel>
                         <Button Grid.Column="1"
                                 Content="Done"
                                 Classes="BtnBase"
                                 Padding="18,5"
                                 Click="BtnEditModeDone_Click"/>
                     </Grid>
                 </Border>

                 <!-- Game List -->
                 <ScrollViewer Name="GameListScrollViewer"
                               Grid.Row="2"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Disabled"
                               PointerWheelChanged="GameListScrollViewer_PointerWheelChanged">
                     <ListBox Name="LstGames"
                              Margin="12"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                          <ListBox.Styles>
                              <Style Selector="ListBoxItem">
                                  <Setter Property="Padding" Value="0,0,0,8"/>
                                  <Setter Property="Background" Value="Transparent"/>
                              </Style>
                              <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                  <Setter Property="Background" Value="Transparent"/>
                              </Style>
                              <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                  <Setter Property="Background" Value="Transparent"/>
                              </Style>
                          </ListBox.Styles>


                         <ListBox.ItemTemplate>
                             <DataTemplate x:DataType="models:Game">
                                 <!-- Game Card -->
                                 <Border Classes="GameCard"
                                         Background="{StaticResource BrBgCard}"
                                         BorderBrush="{StaticResource BrBorderSubtle}"
                                         BorderThickness="1"
                                         CornerRadius="{StaticResource RadiusLarge}"
                                         RenderTransformOrigin="50%,50%"
                                         Padding="20,16">
                                     <Border.Styles>
                                         <Style Selector="Border.GameCard:pointerover">
                                             <Setter Property="BorderBrush" Value="{StaticResource BrBorderDefault}"/>
                                             <Setter Property="Background"  Value="{StaticResource BrBgElevated}"/>
                                             <Setter Property="RenderTransform" Value="scale(1.007)"/>
                                         </Style>
                                         <Style Selector="Border.GameCard">
                                             <Setter Property="RenderTransform" Value="scale(1)"/>
                                             <Setter Property="Transitions">
                                                 <Transitions>
                                                     <BrushTransition Property="Background" Duration="0:0:0.15"/>
                                                     <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                                                     <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
                                                 </Transitions>
                                             </Setter>
                                         </Style>
                                     </Border.Styles>

                                         <Grid>
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="Auto"/> <!-- Cover Art -->
                                                 <ColumnDefinition Width="*"/>
                                                 <ColumnDefinition Width="Auto"/>
                                             </Grid.ColumnDefinitions>

                                             <!-- Cover Art -->
                                             <Border Grid.Column="0" Width="80" Height="120" Margin="0,0,20,0"
                                                     CornerRadius="4" ClipToBounds="True"
                                                     Background="{StaticResource BrBgElevated}"
                                                     BorderBrush="{StaticResource BrBorderSubtle}"
                                                     BorderThickness="1">
                                                 <!--
                                                     <RectangleGeometry RadiusX="4" RadiusY="4" Rect="0,0,80,120"/>
                                                 -->
                                                 <Grid>
                                                     <!-- Fallback Icon -->
                                                     <TextBlock Text="🎮"
                                                                FontSize="36"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Foreground="{StaticResource BrTextSecondary}"
                                                                Opacity="0.5"/>

                                                     <!-- Image (overlays fallback if valid) -->
                                                     <Image Source="{Binding CoverImageUrl, Converter={StaticResource BitmapValueConverter}}" Stretch="UniformToFill" />
                                                 </Grid>
                                             </Border>

                                             <!-- Game info -->
                                             <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                             <!-- Name and Platform -->
                                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,3">
                                                 <!-- Platform Badge -->
                                                 <Border Background="{StaticResource BrBgSurface}"
                                                         BorderBrush="{StaticResource BrBorderSubtle}"
                                                         BorderThickness="1"
                                                         CornerRadius="4" ClipToBounds="True"
                                                         Padding="6,2" Margin="0,0,8,0"
                                                         VerticalAlignment="Center">
                                                     <TextBlock Text="{Binding Platform}"
                                                                Foreground="{StaticResource BrTextSecondary}"
                                                                FontSize="10"
                                                                FontWeight="SemiBold"/>
                                                 </Border>

                                                 <!-- Name -->
                                                 <TextBlock Text="{Binding Name}"
                                                            FontSize="{StaticResource FontSizeSubtitle}"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource BrTextPrimary}"
                                                            VerticalAlignment="Center"/>
                                             </StackPanel>

                                             <!-- Badges row -->
                                             <StackPanel Orientation="Horizontal" Margin="0,10,0,0">

                                                 <!-- DLSS badge -->
                                                 <Border Background="#1A2E1A"
                                                         BorderBrush="#2D5A2D"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Padding="10,3" Margin="0,0,6,0"
                                                         IsVisible="{Binding DlssVersion, Converter={StaticResource NullToVisibilityConverter}}">
                                                     <TextBlock Text="DLSS"
                                                                Foreground="#7FD481"
                                                                FontSize="{StaticResource FontSizeCaption}"
                                                                FontWeight="SemiBold"/>
                                                 </Border>

                                                 <!-- FSR badge -->
                                                 <Border Background="#2E1A1A"
                                                         BorderBrush="#5A2D2D"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Padding="10,3" Margin="0,0,6,0"
                                                         IsVisible="{Binding FsrVersion, Converter={StaticResource NullToVisibilityConverter}}">
                                                     <TextBlock Text="FSR"
                                                                Foreground="#E07070"
                                                                FontSize="{StaticResource FontSizeCaption}"
                                                                FontWeight="SemiBold"/>
                                                 </Border>

                                                 <!-- XeSS badge -->
                                                 <Border Background="#1A1E2E"
                                                         BorderBrush="#2D3A5A"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Padding="10,3" Margin="0,0,6,0"
                                                         IsVisible="{Binding XessVersion, Converter={StaticResource NullToVisibilityConverter}}">
                                                     <TextBlock Text="XeSS"
                                                                Foreground="#7080E0"
                                                                FontSize="{StaticResource FontSizeCaption}"
                                                                FontWeight="SemiBold"/>
                                                 </Border>

                                                 <!-- OptiScaler badge (violet) -->
                                                 <Border Background="#1E1530"
                                                         BorderBrush="{StaticResource BrAccent}"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Padding="10,3" Margin="0,0,6,0"
                                                         IsVisible="{Binding IsOptiscalerInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                     <StackPanel Orientation="Horizontal">
                                                         <TextBlock Text="✦ OptiScaler"
                                                                    Foreground="{StaticResource BrAccent}"
                                                                    FontSize="{StaticResource FontSizeCaption}"
                                                                    FontWeight="Bold"/>
                                                         <TextBlock Text="{Binding OptiscalerVersion, StringFormat=' {0}'}"
                                                                    Foreground="{StaticResource BrAccent}"
                                                                    FontSize="{StaticResource FontSizeCaption}"
                                                                    FontWeight="SemiBold"
                                                                    IsVisible="{Binding OptiscalerVersion, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                     </StackPanel>
                                                 </Border>

                                             </StackPanel>
                                         </StackPanel>

                                         <!-- Actions -->
                                         <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                             <Button Content="&#xE74D;"
                                                     FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                                     Foreground="{StaticResource BrTextSecondary}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FontSize="16"
                                                     Padding="10"
                                                     Margin="0,0,10,0"
                                                     ToolTip.Tip="{DynamicResource TxtRemoveGameTip}"
                                                     IsVisible="{Binding IsManual, Converter={StaticResource BoolToVisibilityConverter}}"
                                                     Click="BtnRemoveGame_Click">
                                                 <Button.Styles>
                                                     <Style Selector="Button:pointerover">
                                                         <Setter Property="Background" Value="#1AFFFFFF"/>
                                                         <Setter Property="Foreground" Value="{StaticResource BrAccentWarm}"/>
                                                     </Style>
                                                 </Button.Styles>
                                             </Button>
                                             <Button Name="BtnFastInstall"
                                                    Classes="BtnBase NormalModeAction"
                                                    Padding="16,8"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource BrAccent}"
                                                    Content="{DynamicResource TxtQuickInstall}"
                                                    Click="BtnFastInstall_Click"
                                                    Loaded="BtnFastInstall_Loaded"/>
                                            <Button Name="BtnManageGame"
                                                    Classes="BtnBase NormalModeAction"
                                                    Padding="20,8"
                                                    VerticalAlignment="Center"
                                                    Click="BtnManage_Click">
                                                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center" Margin="0,0,0,0">
                                                    <TextBlock Grid.Column="0"
                                                               Text="&#xE713;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                                               FontSize="15"
                                                               Foreground="{StaticResource BrTextPrimary}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{DynamicResource TxtManageGame}"
                                                               Foreground="{StaticResource BrTextPrimary}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Button>

                                            <!-- Edit Mode controls (collapsed when not in edit mode; visibility driven by CSS class on LstGames) -->
                                            <StackPanel Name="EditModeControls"
                                                        Classes="EditModePanel"
                                                        Orientation="Horizontal"
                                                        Margin="8,0,0,0"
                                                        Spacing="2">
                                                <!-- Drag handle -->
                                                <Border Name="DragHandle"
                                                        Width="24" Height="36"
                                                        Background="Transparent"
                                                        Cursor="SizeAll"
                                                        ToolTip.Tip="Drag to reorder"
                                                        PointerPressed="DragHandle_PointerPressed"
                                                        Margin="0,0,4,0">
                                                    <TextBlock Text="&#x283F;"
                                                               FontSize="16"
                                                               Foreground="{StaticResource BrTextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <Button Name="BtnMoveUp"
                                                        Width="32" Height="32"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        ToolTip.Tip="Move up"
                                                        Click="BtnMoveUp_Click">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover">
                                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                                        </Style>
                                                    </Button.Styles>
                                                    <TextBlock Text="&#x25B2;"
                                                               FontSize="11"
                                                               Foreground="{StaticResource BrTextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Name="BtnMoveDown"
                                                        Width="32" Height="32"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        ToolTip.Tip="Move down"
                                                        Click="BtnMoveDown_Click">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover">
                                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                                        </Style>
                                                    </Button.Styles>
                                                    <TextBlock Text="&#x25BC;"
                                                               FontSize="11"
                                                               Foreground="{StaticResource BrTextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Name="BtnToggleHide"
                                                        Width="36" Height="32"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        ToolTip.Tip="Hide/show game"
                                                        Click="BtnToggleHide_Click">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover">
                                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                                        </Style>
                                                    </Button.Styles>
                                                    <TextBlock Name="TxtHideIcon"
                                                               Text="&#xE7B3;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                                               FontSize="16"
                                                               Foreground="{StaticResource BrTextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                         </StackPanel>
                                     </Grid>
                                 </Border>
                             </DataTemplate>
                         </ListBox.ItemTemplate>
                     </ListBox>
                 </ScrollViewer>

                 <!-- Game Grid -->
                 <ScrollViewer Name="GameGridScrollViewer"
                               Grid.Row="2"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Disabled"
                               PointerWheelChanged="GameListScrollViewer_PointerWheelChanged"
                               IsVisible="False">
                     <ListBox Name="LstGamesGrid"
                              Margin="12"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalAlignment="Center"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                         <ListBox.ItemsPanel>
                             <ItemsPanelTemplate>
                                 <WrapPanel Orientation="Horizontal" ItemWidth="217" HorizontalAlignment="Center"/>
                             </ItemsPanelTemplate>
                         </ListBox.ItemsPanel>
                         <ListBox.Styles>
                             <Style Selector="ListBoxItem">
                                 <Setter Property="Padding" Value="0,0,12,12"/>
                                 <Setter Property="Background" Value="Transparent"/>
                             </Style>
                             <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                 <Setter Property="Background" Value="Transparent"/>
                             </Style>
                             <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                 <Setter Property="Background" Value="Transparent"/>
                             </Style>
                         </ListBox.Styles>

                         <ListBox.ItemTemplate>
                             <DataTemplate x:DataType="models:Game">
                                 <Border Classes="GameGridCard"
                                         Background="{StaticResource BrBgCard}"
                                         BorderBrush="{StaticResource BrBorderSubtle}"
                                         BorderThickness="1"
                                         CornerRadius="{StaticResource RadiusLarge}"
                                         Width="205"
                                         Padding="0"
                                         PointerEntered="GameGridCard_PointerEntered"
                                         PointerExited="GameGridCard_PointerExited">
                                     <Border.Styles>
                                         <Style Selector="Border.GameGridCard:pointerover">
                                             <Setter Property="BorderBrush" Value="{StaticResource BrBorderDefault}"/>
                                             <Setter Property="Background" Value="{StaticResource BrBgElevated}"/>
                                             <Setter Property="RenderTransform" Value="scale(1.015)"/>
                                         </Style>
                                         <Style Selector="Border.GameGridCard">
                                             <Setter Property="RenderTransform" Value="scale(1)"/>
                                             <Setter Property="Transitions">
                                                 <Transitions>
                                                     <BrushTransition Property="Background" Duration="0:0:0.15"/>
                                                     <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                                                     <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
                                                 </Transitions>
                                             </Setter>
                                         </Style>
                                     </Border.Styles>

                                     <Grid Name="GridCardRoot">
                                         <StackPanel Spacing="10" Margin="8">
                                             <Border Height="280"
                                                     CornerRadius="{StaticResource RadiusMedium}"
                                                     ClipToBounds="True"
                                                     Background="{StaticResource BrBgElevated}"
                                                     BorderBrush="{StaticResource BrBorderSubtle}"
                                                     BorderThickness="1">
                                                 <Grid>
                                                     <TextBlock Text="🎮"
                                                                FontSize="40"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Foreground="{StaticResource BrTextSecondary}"
                                                                Opacity="0.5"/>
                                                     <Image Source="{Binding CoverImageUrl, Converter={StaticResource BitmapValueConverter}}"
                                                            Stretch="UniformToFill"/>

                                                     <Grid Margin="8,8,8,0" VerticalAlignment="Top">
                                                         <Grid.ColumnDefinitions>
                                                             <ColumnDefinition Width="*"/>
                                                             <ColumnDefinition Width="Auto"/>
                                                         </Grid.ColumnDefinitions>

                                                         <Border Grid.Column="0"
                                                                 Background="#BF10131A"
                                                                 BorderBrush="{StaticResource BrBorderSubtle}"
                                                                 BorderThickness="1"
                                                                 CornerRadius="6"
                                                                 Padding="8,3"
                                                                 HorizontalAlignment="Left">
                                                             <TextBlock Text="{Binding Platform}"
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{StaticResource BrTextPrimary}"/>
                                                         </Border>

                                                         <Button Grid.Column="1"
                                                                 Content="&#xE74D;"
                                                                 FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                                                 Foreground="{StaticResource BrTextSecondary}"
                                                                 Background="#BF10131A"
                                                                 BorderBrush="{StaticResource BrBorderSubtle}"
                                                                 BorderThickness="1"
                                                                 FontSize="14"
                                                                 Width="26"
                                                                 Height="24"
                                                                 Padding="0"
                                                                 CornerRadius="6"
                                                                 ToolTip.Tip="{DynamicResource TxtRemoveGameTip}"
                                                                 IsVisible="{Binding IsManual, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                 Click="BtnRemoveGame_Click"/>
                                                     </Grid>

                                                     <Border Background="#E61E1530"
                                                             BorderBrush="{StaticResource BrAccent}"
                                                             BorderThickness="1"
                                                             CornerRadius="6"
                                                             Padding="8,3"
                                                             Margin="8,0,8,8"
                                                             HorizontalAlignment="Left"
                                                             VerticalAlignment="Bottom"
                                                             IsVisible="{Binding IsOptiscalerInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                         <StackPanel Orientation="Horizontal">
                                                             <TextBlock Text="✦ OptiScaler"
                                                                        Foreground="{StaticResource BrAccent}"
                                                                        FontSize="{StaticResource FontSizeCaption}"
                                                                        FontWeight="Bold"/>
                                                             <TextBlock Text="{Binding OptiscalerVersion, StringFormat=' {0}'}"
                                                                        Foreground="{StaticResource BrAccent}"
                                                                        FontSize="{StaticResource FontSizeCaption}"
                                                                        FontWeight="SemiBold"
                                                                        IsVisible="{Binding OptiscalerVersion, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                         </StackPanel>
                                                     </Border>
                                                 </Grid>
                                             </Border>

                                             <TextBlock Text="{Binding Name}"
                                                        MaxLines="2"
                                                        TextTrimming="CharacterEllipsis"
                                                        FontSize="{StaticResource FontSizeBody}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource BrTextPrimary}"/>

                                             <WrapPanel Orientation="Horizontal" ItemHeight="24" VerticalAlignment="Center">
                                                 <Border Background="#1A2E1A"
                                                         BorderBrush="#2D5A2D"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Padding="8,3"
                                                         Margin="0,0,6,0"
                                                         IsVisible="{Binding DlssVersion, Converter={StaticResource NullToVisibilityConverter}}">
                                                     <TextBlock Text="DLSS"
                                                                Foreground="#7FD481"
                                                                FontSize="{StaticResource FontSizeCaption}"
                                                                FontWeight="SemiBold"/>
                                                 </Border>
                                                 <Border Background="#2E1A1A"
                                                         BorderBrush="#5A2D2D"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Padding="8,3"
                                                         Margin="0,0,6,0"
                                                         IsVisible="{Binding FsrVersion, Converter={StaticResource NullToVisibilityConverter}}">
                                                     <TextBlock Text="FSR"
                                                                Foreground="#E07070"
                                                                FontSize="{StaticResource FontSizeCaption}"
                                                                FontWeight="SemiBold"/>
                                                 </Border>
                                                 <Border Background="#1A1E2E"
                                                         BorderBrush="#2D3A5A"
                                                         BorderThickness="1"
                                                         CornerRadius="6"
                                                         Padding="8,3"
                                                         Margin="0,0,6,0"
                                                         IsVisible="{Binding XessVersion, Converter={StaticResource NullToVisibilityConverter}}">
                                                     <TextBlock Text="XeSS"
                                                                Foreground="#7080E0"
                                                                FontSize="{StaticResource FontSizeCaption}"
                                                                FontWeight="SemiBold"/>
                                                 </Border>
                                             </WrapPanel>

                                         </StackPanel>

                                         <Border Name="GridCardHoverOverlay"
                                                 IsVisible="False"
                                                 Opacity="0"
                                                 IsHitTestVisible="False"
                                                 Background="#800B0E16"
                                                 CornerRadius="{StaticResource RadiusLarge}"/>

                                        <StackPanel Name="GridCardHoverActions"
                                                    IsVisible="False"
                                                    Opacity="0"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="10">
                                            <Button Name="BtnFastInstallGrid"
                                                    Classes="BtnBase"
                                                    MinWidth="128"
                                                    Padding="10,6"
                                                    HorizontalAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    Foreground="{StaticResource BrAccent}"
                                                    Content="{DynamicResource TxtQuickInstall}"
                                                    Click="BtnFastInstall_Click"
                                                    Loaded="BtnFastInstall_Loaded"/>
                                            <Button MinWidth="86"
                                                    HorizontalAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    Classes="BtnBase"
                                                    Padding="10,6"
                                                    Click="BtnManage_Click">
                                                <Button.Content>
                                                    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="&#xE713;"
                                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                                                   FontSize="14"
                                                                   Foreground="{StaticResource BrTextPrimary}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,6,0"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{DynamicResource TxtManageGame}"
                                                                   Foreground="{StaticResource BrTextPrimary}"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Button.Content>
                                            </Button>
                                        </StackPanel>

                                        <!-- Edit mode overlay for grid card -->
                                        <Border Name="GridEditOverlayBorder"
                                                Classes="GridEditOverlay"
                                                Background="#660B0E16"
                                                CornerRadius="{StaticResource RadiusLarge}"
                                                Cursor="SizeAll"
                                                PointerPressed="DragHandle_PointerPressed">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                                                <Border Background="{StaticResource BrBgElevated}"
                                                        Opacity="0.92"
                                                        BorderBrush="{StaticResource BrBorderSubtle}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="8"
                                                        Margin="0,0,0,0"
                                                        HorizontalAlignment="Center">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                                        <TextBlock Text="&#x283F;"
                                                                   FontSize="28"
                                                                   Foreground="{StaticResource BrTextSecondary}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="Drag to reorder"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource BrTextSecondary}"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Button Classes="BtnBase"
                                                        Padding="12,5"
                                                        HorizontalAlignment="Center"
                                                        Click="BtnToggleHide_Click">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Name="TxtHideIconGrid"
                                                                   Text="&#xE7B3;"
                                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"
                                                                   FontSize="14"
                                                                   Foreground="{StaticResource BrTextSecondary}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Name="TxtHideLabel"
                                                                   Text="Hide"
                                                                   Foreground="{StaticResource BrTextSecondary}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                     </Grid>
                                 </Border>
                             </DataTemplate>
                         </ListBox.ItemTemplate>
                     </ListBox>
                 </ScrollViewer>

                 <!-- Status Bar -->
                 <Border Grid.Row="3"
                         Background="{StaticResource BrBgDeep}"
                         BorderBrush="{StaticResource BrBorderSubtle}"
                         BorderThickness="0,1,0,0"
                         Padding="24,8">
                     <TextBlock Name="TxtStatus"
                                Text="{DynamicResource TxtStatusReady}"
                                FontSize="{StaticResource FontSizeCaption}"
                                Foreground="{StaticResource BrTextSecondary}"/>
                 </Border>

                 <!-- Ghost canvas: floating drag visuals sit here, above all content -->
                 <Canvas Name="DragGhostCanvas"
                         Grid.Row="0" Grid.RowSpan="4"
                         IsHitTestVisible="False"
                         ZIndex="100"/>

             </Grid> <!-- ViewGames -->

             <!-- ════════════════════════════════════════════════════════
                  2. PROFILES VIEW
                  ════════════════════════════════════════════════════════ -->
             <Grid Name="ViewProfiles" Opacity="0" IsHitTestVisible="False">
                 <Grid.Transitions>
                     <Transitions>
                         <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                     </Transitions>
                 </Grid.Transitions>
                 <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="*"/>
                 </Grid.RowDefinitions>

                 <!-- Header -->
                 <Border Grid.Row="0"
                         Background="{StaticResource BrBgDeep}"
                         BorderBrush="{StaticResource BrBorderSubtle}"
                         BorderThickness="0,0,0,1"
                         Padding="24,18">
                     <StackPanel VerticalAlignment="Center">
                         <TextBlock Text="Profiles"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource BrTextPrimary}"/>
                         <TextBlock Text="Create and manage OptiScaler configuration profiles"
                                    FontSize="12"
                                    Foreground="{StaticResource BrTextSecondary}"
                                    Margin="0,2,0,0"/>
                     </StackPanel>
                 </Border>

                 <!-- Content: action sidebar (left) + profile list (right) -->
                 <Grid Grid.Row="1" ColumnDefinitions="Auto, *">

                     <!-- Action sidebar -->
                     <Border Grid.Column="0"
                             Background="{StaticResource BrBgDeep}"
                             BorderBrush="{StaticResource BrBorderSubtle}"
                             BorderThickness="0,0,1,0"
                             Padding="16,24"
                             Width="230">
                         <StackPanel Spacing="8" VerticalAlignment="Top">
                             <Button Name="BtnNewProfileView"
                                     Content="New Profile"
                                     Classes="BtnPrimary"
                                     HorizontalAlignment="Stretch"
                                     Padding="12,8"
                                     Click="BtnNewProfileView_Click"/>
                             <Button Name="BtnImportProfileView"
                                     Content="Import .ini…"
                                     Classes="BtnSecondary"
                                     HorizontalAlignment="Stretch"
                                     Padding="12,8"
                                     Click="BtnImportProfileView_Click"/>
                             <Border Height="1"
                                     Background="{StaticResource BrBorderSubtle}"
                                     Margin="0,4"/>
                             <Button Name="BtnSetDefaultView"
                                     Content="Set as Default"
                                     Classes="BtnSecondary"
                                     HorizontalAlignment="Stretch"
                                     Padding="12,8"
                                     IsEnabled="False"
                                     Click="BtnSetDefaultView_Click"/>
                             <Button Name="BtnEditProfileView"
                                     Content="Edit"
                                     Classes="BtnSecondary"
                                     HorizontalAlignment="Stretch"
                                     Padding="12,8"
                                     IsEnabled="False"
                                     Click="BtnEditProfileView_Click"/>
                             <Button Name="BtnDuplicateProfileView"
                                     Content="Duplicate"
                                     Classes="BtnSecondary"
                                     HorizontalAlignment="Stretch"
                                     Padding="12,8"
                                     IsEnabled="False"
                                     Click="BtnDuplicateProfileView_Click"/>
                             <Button Name="BtnDeleteProfileView"
                                     Content="Delete"
                                     Classes="BtnSecondary"
                                     HorizontalAlignment="Stretch"
                                     Padding="12,8"
                                     IsEnabled="False"
                                     Click="BtnDeleteProfileView_Click"/>
                             <Border Height="1"
                                     Background="{StaticResource BrBorderSubtle}"
                                     Margin="0,4"/>
                             <TextBlock Name="TxtProfileInfoView"
                                        FontSize="11"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        TextWrapping="Wrap"/>
                         </StackPanel>
                     </Border>

                     <!-- Profile list -->
                     <Grid Grid.Column="1" RowDefinitions="Auto, *">
                         <Border Grid.Row="0" Padding="24,16,24,0">
                             <TextBox Name="TxtProfileSearchView"
                                      Watermark="Search profiles…"
                                      Classes="Input"
                                      Background="{StaticResource BrBgDeep}"
                                      BorderBrush="{StaticResource BrBorderSubtle}"
                                      TextChanged="TxtProfileSearchView_TextChanged"/>
                         </Border>

                         <ScrollViewer Grid.Row="1" Padding="0" Margin="0,8,0,0">
                             <StackPanel Name="PnlProfilesView" Spacing="8" Margin="24,8,24,24"/>
                         </ScrollViewer>
                     </Grid>
                 </Grid>
             </Grid> <!-- ViewProfiles -->

             <!-- ══ 3. PROFILE EDITOR VIEW ══════════════════════════════════════════════ -->
             <Grid Name="ViewProfileEditor" Opacity="0" IsHitTestVisible="False">
                 <Grid.Transitions>
                     <Transitions>
                         <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                     </Transitions>
                 </Grid.Transitions>
                 <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="*"/>
                     <RowDefinition Height="Auto"/>
                 </Grid.RowDefinitions>

                 <!-- Header -->
                 <Border Grid.Row="0"
                         Background="{StaticResource BrBgDeep}"
                         BorderBrush="{StaticResource BrBorderSubtle}"
                         BorderThickness="0,0,0,1"
                         Padding="16,14">
                     <Grid ColumnDefinitions="Auto, *">
                         <Button Grid.Column="0"
                                 Name="BtnEditorBack"
                                 Content="← Profiles"
                                 Classes="BtnSecondary"
                                 Padding="12,8"
                                 VerticalAlignment="Center"
                                 Click="BtnEditorBack_Click"/>
                         <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
                             <TextBlock Name="TxtEditorTitle"
                                        Text="Profile Editor"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource BrTextPrimary}"/>
                             <TextBlock Text="Configure OptiScaler settings for this profile"
                                        FontSize="11"
                                        Foreground="{StaticResource BrTextSecondary}"
                                        Margin="0,2,0,0"/>
                         </StackPanel>
                     </Grid>
                 </Border>

                 <!-- Sidebar + Settings -->
                 <Grid Grid.Row="1" ColumnDefinitions="Auto, *">

                     <!-- Left sidebar: name, description, section nav -->
                     <Border Grid.Column="0"
                             Background="{StaticResource BrBgDeep}"
                             BorderBrush="{StaticResource BrBorderSubtle}"
                             BorderThickness="0,0,1,0"
                             Padding="12,20,12,20"
                             MinWidth="300"
                             MaxWidth="360">
                         <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
                             <StackPanel Grid.Row="0">
                                 <TextBlock Text="Profile Name"
                                            Foreground="{StaticResource BrTextSecondary}"
                                            FontSize="12"
                                            Margin="0,0,0,4"/>
                                 <TextBox Name="TxtProfileNameEd"
                                          Watermark="Enter profile name"
                                          Height="32"/>
                             </StackPanel>

                             <StackPanel Grid.Row="1" Spacing="8">
                                 <StackPanel>
                                     <TextBlock Text="Description"
                                                Foreground="{StaticResource BrTextSecondary}"
                                                FontSize="12"
                                                Margin="0,0,0,4"/>
                                     <TextBox Name="TxtDescriptionEd"
                                              Watermark="Enter profile description (optional)"
                                              Height="32"/>
                                 </StackPanel>

                                 <StackPanel Spacing="4">
                                     <TextBlock Text="Mode"
                                                Foreground="{StaticResource BrTextSecondary}"
                                                FontSize="12"
                                                FontWeight="Bold"
                                                Margin="0,0,0,4"/>
                                     <Grid ColumnDefinitions="*,*">
                                         <Button Name="BtnEasyModeEd"
                                                 Grid.Column="0"
                                                 HorizontalAlignment="Stretch"
                                                 HorizontalContentAlignment="Center"
                                                 Padding="12,8"
                                                 FontSize="12"
                                                 Classes="BtnPrimary"
                                                 Click="BtnEasyModeEd_Click"
                                                 Margin="0,0,2,0">
                                             Easy
                                         </Button>
                                         <Button Name="BtnAdvancedModeEd"
                                                 Grid.Column="1"
                                                 HorizontalAlignment="Stretch"
                                                 HorizontalContentAlignment="Center"
                                                 Padding="12,8"
                                                 FontSize="12"
                                                 Classes="BtnSecondary"
                                                 Click="BtnAdvancedModeEd_Click"
                                                 Margin="2,0,0,0">
                                             Advanced
                                         </Button>
                                     </Grid>
                                 </StackPanel>
                             </StackPanel>

                             <Border Grid.Row="2"
                                     Height="1"
                                     Background="{StaticResource BrBorderSubtle}"/>

                             <ScrollViewer Grid.Row="3"
                                           Margin="0,8,0,0"
                                           VerticalScrollBarVisibility="Auto"
                                           HorizontalScrollBarVisibility="Disabled">
                                 <StackPanel Name="SidebarNavEd" Spacing="8">
                                     <TextBlock Text="Navigation"
                                                FontSize="12"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource BrTextSecondary}"
                                                Margin="0,0,0,8"/>
                                 </StackPanel>
                             </ScrollViewer>
                         </Grid>
                     </Border>

                     <!-- Right: search + settings wrap -->
                     <Grid Grid.Column="1" RowDefinitions="Auto, *">
                         <StackPanel Grid.Row="0" Margin="24,12,24,0">
                             <TextBox Name="TxtSettingsSearchEd"
                                      Watermark="Search settings..."
                                      Classes="Input"
                                      Background="{StaticResource BrBgDeep}"
                                      BorderBrush="{StaticResource BrBorderSubtle}"
                                      TextChanged="TxtSettingsSearchEd_TextChanged"/>
                         </StackPanel>

                         <ScrollViewer Grid.Row="1"
                                       Name="SettingsScrollViewerEd"
                                       Padding="0"
                                       Margin="24,16,24,20">
                             <WrapPanel Name="SectionsWrapEd"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"/>
                         </ScrollViewer>
                     </Grid>
                 </Grid>

                 <!-- Footer -->
                 <Border Grid.Row="2"
                         Padding="24,18"
                         Background="{StaticResource BrBgDeep}"
                         BorderBrush="{StaticResource BrBorderSubtle}"
                         BorderThickness="0,1,0,0">
                     <Grid ColumnDefinitions="*, Auto">
                         <TextBlock Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{StaticResource BrTextSecondary}"
                                    Text="Only configured settings will override OptiScaler defaults"/>
                         <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                             <Button Content="Cancel"
                                     Classes="BtnSecondary"
                                     Padding="16,8"
                                     Click="BtnEditorBack_Click"/>
                             <Button Name="BtnEditorSave"
                                     Content="Save Profile"
                                     Classes="BtnPrimary"
                                     Padding="20,8"
                                     Click="BtnEditorSave_Click"/>
                         </StackPanel>
                     </Grid>
                 </Border>
             </Grid> <!-- ViewProfileEditor -->

             <!-- ════════════════════════════════════════════════════════
                  3. SETTINGS VIEW
                  ════════════════════════════════════════════════════════ -->
             <Grid Name="ViewSettings" Opacity="0" IsHitTestVisible="False">
                 <Grid.Transitions>
                     <Transitions>
                         <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                     </Transitions>
                 </Grid.Transitions>
                 <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="*"/>
                 </Grid.RowDefinitions>

                 <Border Grid.Row="0" Background="{StaticResource BrBgDeep}" BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="0,0,0,1" Padding="24,18">
                     <StackPanel>
                         <TextBlock Text="{DynamicResource TxtSettingsTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrTextPrimary}"/>
                     </StackPanel>
                 </Border>

                 <ScrollViewer Grid.Row="1"
                               VerticalScrollBarVisibility="Auto"
                               Margin="0"
                               Background="Transparent"
                               PointerPressed="SettingsBackground_PointerPressed">
                    <Grid Name="SettingsGrid" Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- App Preferences Header -->
                        <TextBlock Text="{DynamicResource TxtAppPrefs}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Grid.Row="0"/>

                        <!-- Language - Column 0, Row 1 -->
                        <Border Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLarge}"
                                Padding="20,16"
                                Margin="0,0,8,16"
                                Grid.Column="0"
                                Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource TxtLanguage}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtLanguageDesc}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>

                                <ComboBox Name="CmbLanguage"
                                          Grid.Column="1"
                                          Width="160"
                                          VerticalAlignment="Center"
                                          SelectionChanged="CmbLanguage_SelectionChanged">
                                    <ComboBoxItem Tag="en" Content="English"/>
                                    <ComboBoxItem Tag="es" Content="Español"/>
                                    <ComboBoxItem Tag="pt-BR" Content="Português (Brasil)"/>
                                    <ComboBoxItem Tag="fr" Content="Français"/>
                                    <ComboBoxItem Tag="it" Content="Italiano"/>
                                    <ComboBoxItem Tag="ru" Content="Русский"/>
                                    <ComboBoxItem Tag="de" Content="Deutsch"/>
                                    <ComboBoxItem Tag="ja" Content="日本語"/>
                                    <ComboBoxItem Tag="zh-CN" Content="简体中文"/>
                                    <ComboBoxItem Tag="zh-TW" Content="繁體中文"/>
                                    <ComboBoxItem Tag="ko" Content="한국어"/>
                                    <ComboBoxItem Tag="pl" Content="Polski"/>
                                    <ComboBoxItem Tag="tr" Content="Türkçe"/>
                                    <ComboBoxItem Tag="nl" Content="Nederlands"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Cache Management - Column 1, Row 1 -->
                        <Border Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLarge}"
                                Padding="20,16"
                                Margin="8,0,0,16"
                                Grid.Column="1"
                                Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource TxtCacheMgmt}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtCacheDesc}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>

                                <Button Name="BtnManageCache"
                                        Grid.Column="1"
                                        Content="{DynamicResource TxtManage}"
                                        Classes="BtnBase"
                                        Padding="16,8"
                                        VerticalAlignment="Center"
                                        Click="BtnManageCache_Click"/>
                            </Grid>
                        </Border>

                        <!-- Scan Sources - Column 0, Row 2 -->
                        <Border Background="{StaticResource BrBgCard}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Padding="20,16"
                            Margin="0,0,8,16"
                            Grid.Column="0"
                            Grid.Row="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource TxtScanSources}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtScanSourcesDesc}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>

                                <Button Name="BtnManageScanSources"
                                        Grid.Column="1"
                                        Content="{DynamicResource TxtManage}"
                                        Classes="BtnBase"
                                        Padding="16,8"
                                        VerticalAlignment="Center"
                                        Click="BtnManageScanSources_Click"/>
                            </Grid>
                        </Border>

                        <!-- FSR4 INT8 - moved to Column 1, Row 2 to balance layout -->
                        <Border Background="{StaticResource BrBgCard}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Padding="20,16"
                            Margin="8,0,0,16"
                            Grid.Column="1"
                            Grid.Row="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="FSR4 INT8 Default"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="Default FSR4 INT8 mod version pre-selected when opening a game. RDNA 4 GPUs (RX 9000 series) default to None automatically."
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>
                                <ComboBox Name="CmbDefaultExtrasVersion"
                                          Grid.Column="1"
                                          Width="200"
                                          VerticalAlignment="Center"
                                          SelectionChanged="CmbDefaultExtrasVersion_SelectionChanged"/>
                            </Grid>
                        </Border>

                        <!-- Default GPU - Column 1, Row 3 -->
                        <Border Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLarge}"
                                Padding="20,16"
                                Margin="8,0,0,16"
                                Grid.Column="1"
                                Grid.Row="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Default GPU"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="Used for defaults and GPU-specific guidance."
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>
                                <ComboBox Name="CmbDefaultGpu"
                                          Grid.Column="1"
                                          Width="240"
                                          VerticalAlignment="Center"
                                          SelectionChanged="CmbDefaultGpu_SelectionChanged"/>
                            </Grid>
                        </Border>

                        <!-- Auto Scan - Column 0, Row 4 -->
                        <Border Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLarge}"
                                Padding="20,16"
                                Margin="0,0,8,16"
                                Grid.Column="0"
                                Grid.Row="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource TxtAutoScan}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtAutoScanDesc}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>

                                <ToggleSwitch Name="TglAutoScan"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              OnContent="" OffContent=""
                                              IsChecked="True"
                                              IsCheckedChanged="TglAutoScan_IsCheckedChanged"/>
                            </Grid>
                        </Border>

                        <!-- Default OptiScaler Version: Column 1, Row 4 -->
                        <Border Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLarge}"
                                Padding="20,16"
                                Margin="8,0,0,16"
                                Grid.Column="1"
                                Grid.Row="4">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Default OptiScaler Version"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="Pre-selected version when opening Manage or using Quick Install. 'Auto' picks the latest recommended release."
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                    <!-- Stable / Beta channel toggle -->
                                    <Grid ColumnDefinitions="*,*">
                                        <Button Name="BtnOptiDefaultStable"
                                                Grid.Column="0"
                                                Content="Stable"
                                                Classes="BtnPrimary"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="11"
                                                Padding="8,5"
                                                Margin="0,0,2,0"
                                                Click="BtnOptiDefaultStable_Click"/>
                                        <Button Name="BtnOptiDefaultBeta"
                                                Grid.Column="1"
                                                Content="Beta"
                                                Classes="BtnSecondary"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="11"
                                                Padding="8,5"
                                                Margin="2,0,0,0"
                                                Click="BtnOptiDefaultBeta_Click"/>
                                    </Grid>
                                    <ComboBox Name="CmbDefaultOptiScalerVersion"
                                              Width="220"
                                              SelectionChanged="CmbDefaultOptiScalerVersion_SelectionChanged"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Animations - Column 0, Row 5 -->
                        <Border Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLarge}"
                                Padding="20,16"
                                Margin="0,0,8,0"
                                Grid.Column="0"
                                Grid.Row="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource TxtAnimations}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtAnimationsDesc}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,16,0"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                </StackPanel>

                                <ToggleSwitch Name="TglAnimations"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              OnContent="" OffContent=""
                                              IsChecked="True"
                                              IsCheckedChanged="TglAnimations_IsCheckedChanged"/>
                            </Grid>
                        </Border>

                        <!-- SteamGridDB API Key - Column 1, Row 5 (spans full width) -->
                        <Border Background="{StaticResource BrBgCard}"
                                BorderBrush="{StaticResource BrBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusLarge}"
                                Padding="20,16"
                                Margin="8,0,0,0"
                                Grid.Column="1"
                                Grid.Row="5">
                            <Grid RowDefinitions="Auto,Auto">
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource TxtSteamGridApiKey}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrTextPrimary}"/>
                                        <TextBlock Text="{DynamicResource TxtSteamGridApiKeyDesc}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,16,0"
                                                   FontSize="{StaticResource FontSizeCaption}"/>
                                    </StackPanel>

                                    <Button Name="BtnSteamGridApiGuide"
                                            Grid.Column="1"
                                            Content="{DynamicResource TxtSteamGridGetApiKey}"
                                            Classes="BtnBase"
                                            Padding="16,8"
                                            VerticalAlignment="Center"
                                            Click="BtnSteamGridApiGuide_Click"/>
                                </Grid>

                                <TextBox Name="TxtSteamGridApiKey"
                                         Grid.Row="1"
                                         Margin="0,12,0,0"
                                         Watermark="{DynamicResource TxtSteamGridApiKeyPlaceholder}"
                                         LostFocus="TxtSteamGridApiKey_LostFocus"/>
                            </Grid>
                        </Border>
                    </Grid>
                 </ScrollViewer>
             </Grid>

             <!-- ════════════════════════════════════════════════════════
                  3. HELP / COMPONENT INFO VIEW
                  ════════════════════════════════════════════════════════ -->
             <Grid Name="ViewHelp" Opacity="0" IsHitTestVisible="False">
                 <Grid.Transitions>
                     <Transitions>
                         <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                     </Transitions>
                 </Grid.Transitions>
                 <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="*"/>
                 </Grid.RowDefinitions>

                 <!-- Header -->
                <Border Grid.Row="0" Background="{StaticResource BrBgDeep}" BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="0,0,0,1" Padding="24,18">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Help"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrTextPrimary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                 <!-- Component rows -->
                 <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                     <StackPanel Margin="24,20" MaxWidth="600" HorizontalAlignment="Left" Width="600">

                         <!-- GUIDE SECTION -->
                         <TextBlock Text="{DynamicResource TxtGuideTitle}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrTextPrimary}" Margin="0,0,0,12"/>
                         <Button Content="{DynamicResource TxtBtnGuide}"
                                 Name="BtnGuide2"
                                 Click="BtnGuide_Click2"
                                 Classes="BtnBase"
                                 Padding="16,12"
                                 HorizontalAlignment="Left"
                                 Width="150"
                                 Margin="0,0,0,32"/>

                         <!-- ABOUT SECTION -->
                         <TextBlock Text="{DynamicResource TxtAboutTitle}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrTextPrimary}" Margin="0,0,0,12"/>
                         <Border Background="{StaticResource BrBgSurface}" BorderBrush="{StaticResource BrBorderSubtle}" BorderThickness="1" CornerRadius="{StaticResource RadiusMedium}" Padding="16,12">
                             <StackPanel>
                                 <!-- Optiscaler Client -->
                                 <Grid Margin="0,0,0,12">
                                     <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                     <TextBlock Grid.Column="0" Text="Optiscaler Client" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                                     <TextBlock Grid.Column="1" Name="TxtAppVersion" Text="" FontWeight="Bold" Foreground="{StaticResource BrAccent}" VerticalAlignment="Center"/>
                                 </Grid>

                                 <!-- OptiScaler -->
                                 <Grid Margin="0,0,0,12">
                                     <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                     <TextBlock Grid.Column="0" Text="OptiScaler" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                                     <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                         <Border Name="BdOptiUpdate" Background="#2A1F4A" BorderBrush="{StaticResource BrAccent}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,12,0" VerticalAlignment="Center" IsVisible="False">
                                             <TextBlock Text="{DynamicResource TxtUpdateAvail}" FontSize="11" Foreground="{StaticResource BrAccent}"/>
                                         </Border>
                                         <TextBlock Name="TxtOptiVersion" FontWeight="Bold" Foreground="{StaticResource BrAccent}" VerticalAlignment="Center"/>
                                     </StackPanel>
                                 </Grid>

                                 <!-- Fakenvapi -->
                                 <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Fakenvapi" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Name="BtnUpdateFakenvapi" Content="{DynamicResource TxtCheckUpdatesBtn}" Classes="BtnBase" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center" Click="BtnUpdateFakenvapi_Click"/>
                                        <TextBlock Name="TxtFakeVersion" FontWeight="Bold" Foreground="{StaticResource BrAccent}" VerticalAlignment="Center" MinWidth="80" TextAlignment="Right"/>
                                    </StackPanel>
                                 </Grid>

                                 <!-- NukemFG -->
                                 <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="NukemFG" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Name="BtnUpdateNukemFG" Content="{DynamicResource TxtBtnUpdate}" Classes="BtnBase" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center" Click="BtnUpdateNukemFG_Click"/>
                                        <TextBlock Name="TxtNukemVersion" FontWeight="Bold" Foreground="{StaticResource BrAccent}" VerticalAlignment="Center" MinWidth="80" TextAlignment="Right"/>
                                    </StackPanel>
                                 </Grid>

                                 <!-- Build Date -->
                                 <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource TxtBuildDateLbl}" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Name="TxtBuildDate" Text="--/--/----" FontWeight="Bold" Foreground="{StaticResource BrTextSecondary}" VerticalAlignment="Center"/>
                                 </Grid>
            
                                <Separator Background="{StaticResource BrBorderSubtle}" Margin="0,0,0,16"/>
                                 
                                <!-- License Information -->
                                <Border Background="{StaticResource BrBgSurface}" 
                                        BorderBrush="{StaticResource BrBorderSubtle}" 
                                        BorderThickness="1" 
                                        CornerRadius="{StaticResource RadiusMedium}" 
                                        Padding="12,10" 
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="License &amp; Copyright" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="13" 
                                                   Foreground="{StaticResource BrTextPrimary}" 
                                                   Margin="0,0,0,8"/>
                                        <TextBlock TextWrapping="Wrap" 
                                                   FontSize="12" 
                                                   Foreground="{StaticResource BrTextSecondary}" 
                                                   LineHeight="18">
                                            <Run Text="Copyright 2026 Agustín Montaña (Agustinm28)"/><LineBreak/>
                                            <LineBreak/>
                                            <Run Text="Licensed under GPL-3.0-or-later. This is free software: you are free to change and redistribute it under certain conditions. See the LICENSE file for details."/><LineBreak/>
                                            <LineBreak/>
                                            <Run Text="Third-party components (OptiScaler, Fakenvapi, NukemFG, FSR4 INT8) are subject to their respective licenses."/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                 
                                <Separator Background="{StaticResource BrBorderSubtle}" Margin="0,0,0,16"/>
             

                                 <StackPanel Orientation="Horizontal">
                                     <Button Content="{DynamicResource TxtCheckUpdatesBtn}"
                                             Name="BtnCheckUpdates"
                                             Click="BtnCheckUpdates_Click"
                                             Classes="BtnPrimary"
                                             Padding="16,8"
                                             Margin="0,0,12,0"/>
                                     <Button Content="{DynamicResource TxtGithubBtn}"
                                             Name="BtnGithub"
                                             Click="BtnGithub_Click"
                                             Classes="BtnBase"
                                             Padding="16,8"/>
                                 </StackPanel>

                             </StackPanel>
                         </Border>

                     <!-- Content Area -->
                     <ScrollViewer Grid.Column="1"
                                   Name="HelpContentScrollViewer"
                                   VerticalScrollBarVisibility="Auto">
                         <StackPanel Name="HelpContentArea" MaxWidth="700" Margin="32,24,32,48">
                             <!-- Dynamic content will be loaded here -->
                         </StackPanel>
                     </ScrollViewer>
                 </Grid>
             </Grid>

             <!-- SCANNING MODAL OVERLAY (Sits on top of EVERYTHING in column 1) -->
             <Grid Name="OverlayScanning" Background="#B2000000" IsVisible="False" ZIndex="100">
                <Border Background="{StaticResource BrBgElevated}"
                        BorderBrush="{StaticResource BrAccent}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusLarge}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="60,50">
                    <StackPanel>
                        <!-- Animated Dots -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,24">
                            <Ellipse Name="ScanDot1" Width="12" Height="12" Fill="{StaticResource BrAccent}" Margin="4,12,4,0"/>
                            <Ellipse Name="ScanDot2" Width="12" Height="12" Fill="{StaticResource BrAccent}" Margin="4,12,4,0"/>
                            <Ellipse Name="ScanDot3" Width="12" Height="12" Fill="{StaticResource BrAccent}" Margin="4,12,4,0"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource TxtScanningTitle}"
                                   FontSize="{StaticResource FontSizeSubtitle}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrTextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,8"/>
                        <TextBlock Text="{DynamicResource TxtScanningDesc}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
             </Grid>

             <!-- TOAST NOTIFICATION -->
             <Border Name="BdToast"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Bottom"
                     Margin="0,0,0,24"
                     Background="{StaticResource BrBgElevated}"
                     BorderBrush="{StaticResource BrAccent}"
                     BorderThickness="1"
                     CornerRadius="{StaticResource RadiusMedium}"
                     Padding="14,10"
                     IsVisible="False"
                     ZIndex="200">
                 <StackPanel>
                     <StackPanel Orientation="Horizontal">
                         <TextBlock Name="TxtToastIcon"
                                    Text="..."
                                    Foreground="{StaticResource BrAccent}"
                                    FontWeight="Bold"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                         <TextBlock Name="TxtToastMessage"
                                    Text="Working..."
                                    Foreground="{StaticResource BrTextPrimary}"
                                    VerticalAlignment="Center"/>
                     </StackPanel>
                     <ProgressBar Name="PrgToast"
                                  Height="6"
                                  Width="240"
                                  Margin="0,8,0,0"
                                  IsVisible="False"
                                  IsIndeterminate="True"
                                  Minimum="0"
                                  Maximum="100"/>
                 </StackPanel>
             </Border>

             <!-- SECONDARY TOAST (non-blocking notice) -->
             <Border Name="BdToastSecondary"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Bottom"
                     Margin="0,0,0,100"
                     Background="{StaticResource BrBgElevated}"
                     BorderBrush="{StaticResource BrBorderSubtle}"
                     BorderThickness="1"
                     CornerRadius="{StaticResource RadiusMedium}"
                     Padding="12,8"
                     IsVisible="False"
                     ZIndex="210">
                 <StackPanel Orientation="Horizontal">
                     <TextBlock Text="i"
                                Foreground="{StaticResource BrTextSecondary}"
                                FontWeight="Bold"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                     <TextBlock Name="TxtToastSecondaryMessage"
                                Text="Info"
                                Foreground="{StaticResource BrTextPrimary}"
                                VerticalAlignment="Center"/>
                 </StackPanel>
             </Border>

        </Grid>
    </Grid>
</Window>
